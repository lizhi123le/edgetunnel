                            const 有效首包 = 智能剥离填充(首包bytes);
                            if (判断是否是木马 === null) 判断是否是木马 = 有效首包.byteLength >= 58 && 有效首包[56] === 0x0d && 有效首包[57] === 0x0a;
                            if (判断是否是木马) {
