function иҺ·еҸ–дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј(config_JSON, е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„, дҪңдёәдјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁ) {
	let дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј = дҪңдёәдјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁ ? '/' : (config_JSON.йҡҸжңәи·Ҝеҫ„ ? йҡҸжңәи·Ҝеҫ„(е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„) : е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„);
	if (config_JSON.еҗҜз”Ё0RTT && config_JSON.дј иҫ“еҚҸи®® === 'ws' && !дҪңдёәдјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁ) {
		if (!дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј.includes('ed=2560')) {
			дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј = дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј.includes('?') ? (дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј + '&ed=2560') : (дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј + '?ed=2560');
		}
	}
	return дј иҫ“и·Ҝеҫ„еҸӮж•°еҖј;
}

async function Clashи®ўйҳ…й…ҚзҪ®ж–Үд»¶зғӯиЎҘдёҒ(Clash_еҺҹе§Ӣи®ўйҳ…еҶ…е®№, uuid = null, ECHеҗҜз”Ё = false, HOSTS = [], ECH_SNI = null, ECH_DNS, gRPCUserAgent = null) {
    const gRPCUserAgentYAML = gRPCUserAgent ? JSON.stringify(gRPCUserAgent) : null;
    const йңҖиҰҒеӨ„зҗҶgRPC = Boolean(gRPCUserAgentYAML);
    let patchYieldTime = performance.now();
    const dynamicYield = async () => { if (performance.now() - patchYieldTime > 5) { await new Promise(r => setTimeout(r, 0)); patchYieldTime = performance.now(); } };
    
    // gRPC з”ЁжҲ·д»ЈзҗҶеӨ„зҗҶиҫ…еҠ©еҮҪж•°
    const ж·»еҠ InlineGrpcUserAgent = (text) => text.replace(/grpc-opts:\s*\{([\s\S]*?)\}/i, (all, inner) => {
        if (/grpc-user-agent\s*:/i.test(inner)) return all;
        let content = inner.trim();
        if (content.endsWith(',')) content = content.slice(0, -1).trim();
        const patchedContent = content ? `${content}, grpc-user-agent: ${gRPCUserAgentYAML}` : `grpc-user-agent: ${gRPCUserAgentYAML}`;
        return `grpc-opts: {${patchedContent}}`;
    });
    const еҢ№й…ҚеҲ°gRPCзҪ‘з»ң = (text) => /(?:^|[,{])\s*network:\s*(?:"grpc"|'grpc'|grpc)(?=\s*(?:[,}\n#]|$))/mi.test(text);
    
    const ж·»еҠ Flowж јејҸgRPCUserAgent = (nodeText) => {
        if (!йңҖиҰҒеӨ„зҗҶgRPC || !еҢ№й…ҚеҲ°gRPCзҪ‘з»ң(nodeText) || /grpc-user-agent\s*:/i.test(nodeText)) return nodeText;
        if (/grpc-opts:\s*\{/i.test(nodeText)) return ж·»еҠ InlineGrpcUserAgent(nodeText);
        return nodeText.replace(/\}(\s*)$/, `, grpc-opts: {grpc-user-agent: ${gRPCUserAgentYAML}}}$1`);
    };
    
    let clash_yaml = Clash_еҺҹе§Ӣи®ўйҳ…еҶ…е®№.replace(/mode:\s*Rule\b/g, 'mode: rule');
    // еҹәзЎҖ DNS й…ҚзҪ®еқ—пјҲдёҚеҗ« nameserver-policyпјү
    const baseDnsBlock = `dns:
  enable: true
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
    - 114.114.114.114
  use-hosts: true
  nameserver:
    - https://sm2.doh.pub/dns-query
    - https://dns.alidns.com/dns-query
  fallback:
    - 8.8.4.4
    - 208.67.220.220
  fallback-filter:
    geoip: true
    geoip-code: CN
    ipcidr:
      - 240.0.0.0/4
      - 127.0.0.1/32
      - 0.0.0.0/32
    domain:
      - '+.google.com'
      - '+.facebook.com'
      - '+.youtube.com'
`;

    // жЈҖжҹҘжҳҜеҗҰеӯҳеңЁ dns: еӯ—ж®өпјҲеҸҜиғҪеңЁд»»ж„ҸиЎҢпјҢиЎҢйҰ–ж— зј©иҝӣпјү
    const hasDns = /^dns:\s*(?:\n|$)/m.test(clash_yaml);

    // ж— и®ә ECH жҳҜеҗҰеҗҜз”ЁпјҢйғҪзЎ®дҝқеӯҳеңЁ dns: й…ҚзҪ®еқ—
    if (!hasDns) {
        clash_yaml = baseDnsBlock + clash_yaml;
    }
    await dynamicYield();

    // еҰӮжһң ECH_SNI еӯҳеңЁпјҢж·»еҠ еҲ° HOSTS ж•°з»„дёӯ
    if (ECH_SNI && !HOSTS.includes(ECH_SNI)) HOSTS.push(ECH_SNI);

    // еҰӮжһң ECH еҗҜз”Ёдё” HOSTS жңүж•ҲпјҢж·»еҠ  nameserver-policy
    if (ECHеҗҜз”Ё && HOSTS.length > 0) {
        // з”ҹжҲҗ HOSTS зҡ„ nameserver-policy жқЎзӣ®
        const hostsEntries = HOSTS.map(host => `    "${host}": ${ECH_DNS ? ECH_DNS : ''}`).join('\n');
        await dynamicYield();

        // жЈҖжҹҘжҳҜеҗҰеӯҳеңЁ nameserver-policy:
        const hasNameserverPolicy = /^\s{2}nameserver-policy:\s*(?:\n|$)/m.test(clash_yaml);

        if (hasNameserverPolicy) {
            // еӯҳеңЁ nameserver-policy:пјҢеңЁе…¶еҗҺж·»еҠ  HOSTS жқЎзӣ®
            clash_yaml = clash_yaml.replace(
                /^(\s{2}nameserver-policy:\s*\n)/m,
                `$1${hostsEntries}\n`
            );
        } else {
            // дёҚеӯҳеңЁ nameserver-policy:пјҢйңҖиҰҒеңЁ dns: еқ—еҶ…ж·»еҠ ж•ҙдёӘ nameserver-policy
            const lines = clash_yaml.split('\n');
            let dnsBlockEndIndex = -1;
            let inDnsBlock = false;

            for (let i = 0; i < lines.length; i++) {
                const line = lines[i];
                if (/^dns:\s*$/.test(line)) {
                    inDnsBlock = true;
                    continue;
                }
                if (inDnsBlock) {
                    // жЈҖжҹҘжҳҜеҗҰжҳҜж–°зҡ„йЎ¶зә§еӯ—ж®өпјҲиЎҢйҰ–ж— з©әж јдё”дёҚжҳҜз©әиЎҢдё”дёҚжҳҜжіЁйҮҠпјү
                    if (/^[a-zA-Z]/.test(line)) {
                        dnsBlockEndIndex = i;
                        break;
                    }
                }
            }

            // еңЁ dns еқ—жң«е°ҫжҸ’е…Ҙ nameserver-policy
            const nameserverPolicyBlock = `  nameserver-policy:\n${hostsEntries}`;
            if (dnsBlockEndIndex !== -1) {
                lines.splice(dnsBlockEndIndex, 0, nameserverPolicyBlock);
            } else {
                // dns: жҳҜжңҖеҗҺдёҖдёӘйЎ¶зә§еқ—пјҢеңЁж–Үд»¶жң«е°ҫж·»еҠ 
                lines.push(nameserverPolicyBlock);
            }
            clash_yaml = lines.join('\n');
        }
    }

    // еҰӮжһңжІЎжңү uuid жҲ– ECH жңӘеҗҜз”ЁпјҢзӣҙжҺҘиҝ”еӣһ
    if (!uuid || !ECHеҗҜз”Ё) return clash_yaml;

    // ECH еҗҜз”Ёж—¶пјҢеӨ„зҗҶд»ЈзҗҶиҠӮзӮ№ж·»еҠ  ech-opts
    const lines = clash_yaml.split('\n');
    const processedLines = [];
    let i = 0;

    while (i < lines.length) {
        const line = lines[i];
        const trimmedLine = line.trim();
        
        // еҠЁжҖҒи®©еҮәCPU
        await dynamicYield();

        // еӨ„зҗҶиЎҢж јејҸпјҲFlowпјүпјҡ- {name: ..., uuid: ..., ...}
        if (trimmedLine.startsWith('- {') && (trimmedLine.includes('uuid:') || trimmedLine.includes('password:'))) {
            let fullNode = line;
            let braceCount = (line.match(/\{/g) || []).length - (line.match(/\}/g) || []).length;

            // еҰӮжһңжӢ¬еҸ·дёҚеҢ№й…ҚпјҢз»§з»ӯиҜ»еҸ–дёӢдёҖиЎҢ
            while (braceCount > 0 && i + 1 < lines.length) {
                i++;
                fullNode += '\n' + lines[i];
                braceCount += (lines[i].match(/\{/g) || []).length - (lines[i].match(/\}/g) || []).length;
            }

            // иҺ·еҸ–д»ЈзҗҶзұ»еһӢ
            const typeMatch = fullNode.match(/type:\s*(\w+)/);
            const proxyType = typeMatch ? typeMatch[1] : 'vless';

            // ж №жҚ®д»ЈзҗҶзұ»еһӢзЎ®е®ҡиҰҒжҹҘжүҫзҡ„еӯ—ж®ө
            let credentialField = 'uuid';
            if (proxyType === 'trojan') {
                credentialField = 'password';
            }

            // жЈҖжҹҘеҜ№еә”еӯ—ж®өзҡ„еҖјжҳҜеҗҰеҢ№й…Қ
            const credentialPattern = new RegExp(`${credentialField}:\\s*([^,}\\n]+)`);
            const credentialMatch = fullNode.match(credentialPattern);

            if (credentialMatch && credentialMatch[1].trim() === uuid.trim()) {
                const nodeSNI = (ECH_SNI && ECH_SNI !== 'auto') ? ECH_SNI : йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(HOSTS[Math.floor(Math.random() * HOSTS.length)]);
                // еңЁжңҖеҗҺдёҖдёӘ}еүҚж·»еҠ ech-opts
                fullNode = fullNode.replace(/\}(\s*)$/, `, ech-opts: {enable: true${nodeSNI ? `, query-server-name: ${nodeSNI}` : ''}}}$1`);
            }

            processedLines.push(fullNode);
            i++;
        }
        // еӨ„зҗҶеқ—ж јејҸпјҲBlockпјүпјҡ- name: ..., еҗҺз»ӯиЎҢдёәеұһжҖ§
        else if (trimmedLine.startsWith('- name:')) {
            // ж”¶йӣҶе®Ңж•ҙзҡ„д»ЈзҗҶиҠӮзӮ№е®ҡд№ү
            let nodeLines = [line];
            let baseIndent = line.search(/\S/);
            let topLevelIndent = baseIndent + 2; // йЎ¶зә§еұһжҖ§зҡ„зј©иҝӣ
            i++;

            // з»§з»ӯиҜ»еҸ–иҝҷдёӘиҠӮзӮ№зҡ„жүҖжңүеұһжҖ§
            while (i < lines.length) {
                const nextLine = lines[i];
                const nextTrimmed = nextLine.trim();

                // еҰӮжһңжҳҜз©әиЎҢпјҢеҢ…еҗ«е®ғдҪҶдёҚз»§з»ӯ
                if (!nextTrimmed) {
                    nodeLines.push(nextLine);
                    i++;
                    break;
                }

                const nextIndent = nextLine.search(/\S/);

                // еҰӮжһңзј©иҝӣе°ҸдәҺзӯүдәҺеҹәзЎҖзј©иҝӣдё”дёҚжҳҜз©әиЎҢпјҢиҜҙжҳҺиҠӮзӮ№з»“жқҹдәҶ
                if (nextIndent <= baseIndent && nextTrimmed.startsWith('- ')) {
                    break;
                }

                // еҰӮжһңзј©иҝӣжӣҙе°ҸпјҢиҠӮзӮ№д№ҹз»“жқҹдәҶ
                if (nextIndent < baseIndent && nextTrimmed) {
                    break;
                }

                nodeLines.push(nextLine);
                i++;
            }

            // иҺ·еҸ–д»ЈзҗҶзұ»еһӢ
            const nodeText = nodeLines.join('\n');
            const typeMatch = nodeText.match(/type:\s*(\w+)/);
            const proxyType = typeMatch ? typeMatch[1] : 'vless';

            // ж №жҚ®д»ЈзҗҶзұ»еһӢзЎ®е®ҡиҰҒжҹҘжүҫзҡ„еӯ—ж®ө
            let credentialField = 'uuid';
            if (proxyType === 'trojan') {
                credentialField = 'password';
            }

            // жЈҖжҹҘиҝҷдёӘиҠӮзӮ№зҡ„еҜ№еә”еӯ—ж®өжҳҜеҗҰеҢ№й…Қ
            const credentialPattern = new RegExp(`${credentialField}:\\s*([^\\n]+)`);
            const credentialMatch = nodeText.match(credentialPattern);

            if (credentialMatch && credentialMatch[1].trim() === uuid.trim()) {
                // жүҫеҲ°еңЁе“ӘйҮҢжҸ’е…Ҙech-opts
                // зӯ–з•ҘпјҡеңЁжңҖеҗҺдёҖдёӘйЎ¶зә§еұһжҖ§еҗҺйқўжҸ’е…ҘпјҢжҲ–еңЁws-optsд№ӢеүҚжҸ’е…Ҙ
                let insertIndex = -1;

                for (let j = nodeLines.length - 1; j >= 0; j--) {
                    // и·іиҝҮз©әиЎҢпјҢжүҫеҲ°иҠӮзӮ№дёӯжңҖеҗҺдёҖдёӘйқһз©әиЎҢпјҲеҸҜиғҪжҳҜйЎ¶зә§еұһжҖ§жҲ–е…¶еӯҗйЎ№пјү
                    if (nodeLines[j].trim()) {
                        insertIndex = j;
                        break;
                    }
                }

                if (insertIndex >= 0) {
                    const indent = ' '.repeat(topLevelIndent);
                    const nodeSNI = (ECH_SNI && ECH_SNI !== 'auto') ? ECH_SNI : йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(HOSTS[Math.floor(Math.random() * HOSTS.length)]);
                    // еңЁиҠӮзӮ№жң«е°ҫпјҲжңҖеҗҺдёҖдёӘеұһжҖ§еқ—д№ӢеҗҺпјүжҸ’е…Ҙ ech-opts еұһжҖ§
                    const echOptsLines = [
                        `${indent}ech-opts:`,
                        `${indent}  enable: true`
                    ];
                    if (nodeSNI) echOptsLines.push(`${indent}  query-server-name: ${nodeSNI}`);
                    nodeLines.splice(insertIndex + 1, 0, ...echOptsLines);
                }
            }

            processedLines.push(...nodeLines);
        } else {
            processedLines.push(line);
            i++;
        }
    }

    return processedLines.join('\n');
}

async function Singboxи®ўйҳ…й…ҚзҪ®ж–Үд»¶зғӯиЎҘдёҒ(SingBox_еҺҹе§Ӣи®ўйҳ…еҶ…е®№, uuid = null, fingerprint = "chrome", ECHеҗҜз”Ё = false, HOSTS = [], ECH_SNI = null, ECH_DNS = null) {
    let patchYieldTime = performance.now();
    const dynamicYield = async () => { if (performance.now() - patchYieldTime > 5) { await new Promise(r => setTimeout(r, 0)); patchYieldTime = performance.now(); } };
    const sb_json_text = SingBox_еҺҹе§Ӣи®ўйҳ…еҶ…е®№.replace('1.1.1.1', '8.8.8.8').replace('1.0.0.1', '8.8.4.4');
    try {
        let config = JSON.parse(sb_json_text);

        // --- UUID еҢ№й…ҚиҠӮзӮ№зҡ„ TLS зғӯиЎҘдёҒ (utls & ech) ---
        if (uuid) {
            config.outbounds.forEach(outbound => {
                if ((outbound.uuid && outbound.uuid === uuid) || (outbound.password && outbound.password === uuid)) {
                    if (!outbound.tls) {
                        outbound.tls = { enabled: true };
                    }

                    if (fingerprint) {
                        outbound.tls.utls = {
                            enabled: true,
                            fingerprint: fingerprint
                        };
                    }

                    if (ECHеҗҜз”Ё) {
                        const nodeSNI = (ECH_SNI && ECH_SNI !== 'auto') ? ECH_SNI : йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(HOSTS[Math.floor(Math.random() * HOSTS.length)]);
                        outbound.tls.ech = {
                            enabled: true,
                            query_server_name: nodeSNI
                        };
                    }
                }
            });
        }

        return JSON.stringify(config, null, 2);
    } catch (e) {
        console.error("SingboxзғӯиЎҘдёҒжү§иЎҢеӨұиҙҘ:", e);
        return JSON.stringify(JSON.parse(sb_json_text), null, 2);
    }
}

async function Surgeи®ўйҳ…й…ҚзҪ®ж–Үд»¶зғӯиЎҘдёҒ(content, url, config_JSON) {
    const жҜҸиЎҢеҶ…е®№ = content.includes('\r\n') ? content.split('\r\n') : content.split('\n');
    const е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„ = config_JSON.йҡҸжңәи·Ҝеҫ„ ? йҡҸжңәи·Ҝеҫ„(config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„) : config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„;
    let иҫ“еҮәеҶ…е®№ = "";
    let lastYieldTime = performance.now();
    for (let x of жҜҸиЎҢеҶ…е®№) {
        if (x.includes('= tro' + 'jan,') && !x.includes('ws=true') && !x.includes('ws-path=')) {
            const host = x.split("sni=")[1].split(",")[0];
            const еӨҮж”№еҶ…е®№ = `sni=${host}, skip-cert-verify=${config_JSON.и·іиҝҮиҜҒд№ҰйӘҢиҜҒ}`;
            const жӯЈзЎ®еҶ…е®№ = `sni=${host}, skip-cert-verify=${config_JSON.и·іиҝҮиҜҒд№ҰйӘҢиҜҒ}, ws=true, ws-path=${е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„.replace(/,/g, '%2C')}, ws-headers=Host:"${host}"`;
            иҫ“еҮәеҶ…е®№ += x.replace(new RegExp(еӨҮж”№еҶ…е®№, 'g'), жӯЈзЎ®еҶ…е®№).replace("[", "").replace("]", "") + '\n';
        } else {
            иҫ“еҮәеҶ…е®№ += x + '\n';
        }
        if (performance.now() - lastYieldTime > 5) { await new Promise(r => setTimeout(r, 0)); lastYieldTime = performance.now(); }
    }

    иҫ“еҮәеҶ…е®№ = `#!MANAGED-CONFIG ${url} interval=${config_JSON.дјҳйҖүи®ўйҳ…з”ҹжҲҗ.SUBUpdateTime * 60 * 60} strict=false` + иҫ“еҮәеҶ…е®№.substring(иҫ“еҮәеҶ…е®№.indexOf('\n'));
    return иҫ“еҮәеҶ…е®№;
}

async function иҜ·жұӮж—Ҙеҝ—и®°еҪ•(env, request, и®ҝй—®IP, иҜ·жұӮзұ»еһӢ = "Get_SUB", config_JSON, жҳҜеҗҰеҶҷе…ҘKVж—Ҙеҝ— = true) {
    try {
        const еҪ“еүҚж—¶й—ҙ = new Date();
        // ж—Ҙеҝ—и„ұж•Ҹпјҡд»…и®°еҪ• pathnameпјҢдёҚи®°еҪ•е®Ңж•ҙ URLпјҲеҸҜиғҪеҗ«ж•Ҹж„ҹ tokenпјү
        const иҜ·жұӮURL = new URL(request.url);
        const и„ұж•ҸURL = иҜ·жұӮURL.pathname + (иҜ·жұӮURL.search ? '[еҸӮж•°е·Ійҡҗи—Ҹ]' : '');
        // UA еӯ—ж®өйҷҗеҲ¶й•ҝеәҰпјҲйҳІжӯўиҝҮй•ҝпјү
        const еҺҹе§ӢUA = request.headers.get('User-Agent') || 'Unknown';
        const и„ұж•ҸUA = еҺҹе§ӢUA.length > 200 ? еҺҹе§ӢUA.slice(0, 200) + '...' : еҺҹе§ӢUA;
        
        const ж—Ҙеҝ—еҶ…е®№ = { 
            TYPE: иҜ·жұӮзұ»еһӢ, 
            IP: и®ҝй—®IP, 
            ASN: `AS${request.cf?.asn || '0'} ${request.cf?.asOrganization || 'Unknown'}`, 
            CC: `${request.cf?.country || 'N/A'} ${request.cf?.city || 'N/A'}`, 
            URL: и„ұж•ҸURL, 
            UA: и„ұж•ҸUA, 
            TIME: еҪ“еүҚж—¶й—ҙ.getTime() 
        };
        
        if (config_JSON.TG.еҗҜз”Ё) {
            try {
                const TG_TXT = await withTimeout(env.KV.get('tg.json'), 3000);
                if (TG_TXT) {
                    const TG_JSON = JSON.parse(TG_TXT);
                    await sendMessage(TG_JSON.BotToken, TG_JSON.ChatID, ж—Ҙеҝ—еҶ…е®№, config_JSON);
                }
            } catch (error) { console.error(`иҜ»еҸ–tg.jsonеҮәй”ҷ: ${error.message}`) }
        }
        жҳҜеҗҰеҶҷе…ҘKVж—Ҙеҝ— = ['1', 'true'].includes(env.OFF_LOG) ? false : жҳҜеҗҰеҶҷе…ҘKVж—Ҙеҝ—;
        if (!жҳҜеҗҰеҶҷе…ҘKVж—Ҙеҝ—) return;
        
        let ж—Ҙеҝ—ж•°з»„ = [];
        const зҺ°жңүж—Ҙеҝ— = await withTimeout(env.KV.get('log.json'), 3000);
        // KV ж—Ҙеҝ—жҺ§еҲ¶пјҡж”№з”ЁжқЎзӣ®ж•°йҷҗеҲ¶пјҲжӣҙеҸҜйқ пјү
        const жңҖеӨ§ж—Ҙеҝ—жқЎж•° = 1000;
        
        if (зҺ°жңүж—Ҙеҝ—) {
            try {
                ж—Ҙеҝ—ж•°з»„ = JSON.parse(зҺ°жңүж—Ҙеҝ—);
                if (!Array.isArray(ж—Ҙеҝ—ж•°з»„)) { ж—Ҙеҝ—ж•°з»„ = [ж—Ҙеҝ—еҶ…е®№]; }
                else if (иҜ·жұӮзұ»еһӢ !== "Get_SUB") {
                    const дёүеҚҒеҲҶй’ҹеүҚж—¶й—ҙжҲі = еҪ“еүҚж—¶й—ҙ.getTime() - 30 * 60 * 1000;
                    if (ж—Ҙеҝ—ж•°з»„.some(log => log.TYPE !== "Get_SUB" && log.IP === и®ҝй—®IP && log.URL === и„ұж•ҸURL && log.UA === и„ұж•ҸUA && log.TIME >= дёүеҚҒеҲҶй’ҹеүҚж—¶й—ҙжҲі)) return;
                    ж—Ҙеҝ—ж•°з»„.push(ж—Ҙеҝ—еҶ…е®№);
                    // жҢүжқЎж•°йҷҗеҲ¶пјҲжӣҙеҸҜйқ пјү
                    while (ж—Ҙеҝ—ж•°з»„.length > жңҖеӨ§ж—Ҙеҝ—жқЎж•°) ж—Ҙеҝ—ж•°з»„.shift();
                } else {
                    ж—Ҙеҝ—ж•°з»„.push(ж—Ҙеҝ—еҶ…е®№);
                    while (ж—Ҙеҝ—ж•°з»„.length > жңҖеӨ§ж—Ҙеҝ—жқЎж•°) ж—Ҙеҝ—ж•°з»„.shift();
                }
            } catch (e) { ж—Ҙеҝ—ж•°з»„ = [ж—Ҙеҝ—еҶ…е®№]; }
        } else { ж—Ҙеҝ—ж•°з»„ = [ж—Ҙеҝ—еҶ…е®№]; }
        
        await withTimeout(env.KV.put('log.json', JSON.stringify(ж—Ҙеҝ—ж•°з»„, null, 2)), 3000);
    } catch (error) { console.error(`ж—Ҙеҝ—и®°еҪ•еӨұиҙҘ: ${error.message}`); }
}

async function sendMessage(BotToken, ChatID, ж—Ҙеҝ—еҶ…е®№, config_JSON) {
    if (!BotToken || !ChatID) return;

    try {
        const иҜ·жұӮж—¶й—ҙ = new Date(ж—Ҙеҝ—еҶ…е®№.TIME).toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' });
        const иҜ·жұӮURL = new URL(ж—Ҙеҝ—еҶ…е®№.URL);
        const msg = `<b>#${config_JSON.дјҳйҖүи®ўйҳ…з”ҹжҲҗ.SUBNAME} ж—Ҙеҝ—йҖҡзҹҘ</b>\n\n` +
            `рҹ“Ң <b>зұ»еһӢпјҡ</b>#${ж—Ҙеҝ—еҶ…е®№.TYPE}\n` +
            `рҹҢҗ <b>IPпјҡ</b><code>${ж—Ҙеҝ—еҶ…е®№.IP}</code>\n` +
            `рҹ“Қ <b>дҪҚзҪ®пјҡ</b>${ж—Ҙеҝ—еҶ…е®№.CC}\n` +
            `рҹҸў <b>ASNпјҡ</b>${ж—Ҙеҝ—еҶ…е®№.ASN}\n` +
            `рҹ”— <b>еҹҹеҗҚпјҡ</b><code>${иҜ·жұӮURL.host}</code>\n` +
            `рҹ”Қ <b>и·Ҝеҫ„пјҡ</b><code>${иҜ·жұӮURL.pathname + иҜ·жұӮURL.search}</code>\n` +
            `рҹӨ– <b>UAпјҡ</b><code>${ж—Ҙеҝ—еҶ…е®№.UA}</code>\n` +
            `рҹ“… <b>ж—¶й—ҙпјҡ</b>${иҜ·жұӮж—¶й—ҙ}\n` +
            `${config_JSON.CF.Usage.success ? `рҹ“Ҡ <b>иҜ·жұӮз”ЁйҮҸпјҡ</b>${config_JSON.CF.Usage.total}/${config_JSON.CF.Usage.max} <b>${((config_JSON.CF.Usage.total / config_JSON.CF.Usage.max) * 100).toFixed(2)}%</b>\n` : ''}`;

        const url = `https://api.telegram.org/bot${BotToken}/sendMessage?chat_id=${ChatID}&parse_mode=HTML&text=${encodeURIComponent(msg)}`;
        return fetchWithTimeout(url, {
            method: 'GET',
            headers: {
                'Accept': 'text/html,application/xhtml+xml,application/xml;',
                'Accept-Encoding': 'gzip, deflate, br',
                'User-Agent': ж—Ҙеҝ—еҶ…е®№.UA || 'Unknown',
            }
        }, 10000);
    } catch (error) { console.error('Error sending message:', error) }
}

function жҺ©з Ғж•Ҹж„ҹдҝЎжҒҜ(ж–Үжң¬, еүҚзјҖй•ҝеәҰ = 3, еҗҺзјҖй•ҝеәҰ = 2) {
    if (!ж–Үжң¬ || typeof ж–Үжң¬ !== 'string') return ж–Үжң¬;
    if (ж–Үжң¬.length <= еүҚзјҖй•ҝеәҰ + еҗҺзјҖй•ҝеәҰ) return ж–Үжң¬; // еҰӮжһңй•ҝеәҰеӨӘзҹӯпјҢзӣҙжҺҘиҝ”еӣһ

    const еүҚзјҖ = ж–Үжң¬.slice(0, еүҚзјҖй•ҝеәҰ);
    const еҗҺзјҖ = ж–Үжң¬.slice(-еҗҺзјҖй•ҝеәҰ);
    const жҳҹеҸ·ж•°йҮҸ = ж–Үжң¬.length - еүҚзјҖй•ҝеәҰ - еҗҺзјҖй•ҝеәҰ;

    return `${еүҚзјҖ}${'*'.repeat(жҳҹеҸ·ж•°йҮҸ)}${еҗҺзјҖ}`;
}

// иҫ…еҠ©еҮҪж•°пјҡе°Ҷ ArrayBuffer жҲ– Uint8Array иҪ¬еҚҒе…ӯиҝӣеҲ¶еӯ—з¬ҰдёІ
const hexEncode = (buffer) => [...new Uint8Array(buffer)].map(b => b.toString(16).padStart(2, '0')).join('');

// ж–°еўһпјҡSHA-256 е“ҲеёҢеҮҪж•°пјҲз”ЁдәҺйқһеҚҸи®®еҶ…йғЁеңәжҷҜпјү
async function SHA256Hash(ж–Үжң¬) {
    return hexEncode(await crypto.subtle.digest('SHA-256', SSж–Үжң¬зј–з ҒеҷЁ.encode(ж–Үжң¬)));
}

// ж–°еўһпјҡHMAC-SHA256 зӯҫеҗҚеҮҪж•°пјҲз”ЁдәҺ Cookie зӯҫеҗҚпјү
async function HMACSHA256(ж¶ҲжҒҜ, еҜҶй’Ҙ) {
    const keyData = SSж–Үжң¬зј–з ҒеҷЁ.encode(еҜҶй’Ҙ);
    const messageData = SSж–Үжң¬зј–з ҒеҷЁ.encode(ж¶ҲжҒҜ);
    const cryptoKey = await crypto.subtle.importKey('raw', keyData, { name: 'HMAC', hash: 'SHA-256' }, false, ['sign']);
    return hexEncode(await crypto.subtle.sign('HMAC', cryptoKey, messageData));
}

// ж–°еўһпјҡж—¶еәҸе®үе…ЁжҜ”иҫғеҮҪж•°
async function ж—¶еәҸе®үе…ЁжҜ”иҫғ(е·ІзҹҘж–Үжң¬, иҫ“е…Ҙж–Үжң¬) {
    if (typeof е·ІзҹҘж–Үжң¬ !== 'string' || typeof иҫ“е…Ҙж–Үжң¬ !== 'string') return false;
    if (е·ІзҹҘж–Үжң¬.length !== иҫ“е…Ҙж–Үжң¬.length) return false;
    const е·ІзҹҘBuffer = SSж–Үжң¬зј–з ҒеҷЁ.encode(е·ІзҹҘж–Үжң¬);
    const иҫ“е…ҘBuffer = SSж–Үжң¬зј–з ҒеҷЁ.encode(иҫ“е…Ҙж–Үжң¬);
    try {
        return await crypto.subtle.timingSafeEqual(е·ІзҹҘBuffer, иҫ“е…ҘBuffer);
    } catch (e) {
        // йҷҚзә§ж–№жЎҲпјҡйҖҗеӯ—иҠӮжҜ”иҫғпјҲжҒ’е®ҡж—¶й—ҙпјү
        let result = 0;
        for (let i = 0; i < е·ІзҹҘBuffer.length; i++) {
            result |= е·ІзҹҘBuffer[i] ^ иҫ“е…ҘBuffer[i];
        }
        return result === 0;
    }
}

// дҝқз•ҷ MD5MD5 з”ЁдәҺ SS еҚҸи®®е…је®№жҖ§пјҲUUID з”ҹжҲҗзӯүпјү
async function MD5MD5(ж–Үжң¬) {
    const з¬¬дёҖж¬ЎеҚҒе…ӯиҝӣеҲ¶ = hexEncode(await crypto.subtle.digest('MD5', SSж–Үжң¬зј–з ҒеҷЁ.encode(ж–Үжң¬)));
    return hexEncode(await crypto.subtle.digest('MD5', SSж–Үжң¬зј–з ҒеҷЁ.encode(з¬¬дёҖж¬ЎеҚҒе…ӯиҝӣеҲ¶.slice(7, 27)))).toLowerCase();
}

// ============================================================
// йҖҹзҺҮйҷҗеҲ¶еҮҪж•°пјҲдҪҝз”Ё KV еӯҳеӮЁпјү
// ============================================================

// жЈҖжҹҘзҷ»еҪ•йҖҹзҺҮйҷҗеҲ¶пјҲ5ж¬Ў/10еҲҶй’ҹпјү
async function жЈҖжҹҘзҷ»еҪ•йҖҹзҺҮйҷҗеҲ¶(и®ҝй—®IP, env) {
    if (!env?.KV) return true; // ж—  KV еҲҷж”ҫиЎҢ
    const key = `login_rl:${и®ҝй—®IP}`;
    const now = Date.now();
    const windowMs = 10 * 60 * 1000; // 10еҲҶй’ҹ
    try {
        const data = await env.KV.get(key, 'json') || { count: 0, resetAt: now + windowMs };
        if (now > data.resetAt) {
            data.count = 0;
            data.resetAt = now + windowMs;
        }
        if (data.count >= 5) return false; // и¶…иҝҮйҷҗеҲ¶
        data.count++;
        await env.KV.put(key, JSON.stringify(data), { expirationTtl: 600 });
        return true;
    } catch (e) {
        console.error('[йҖҹзҺҮйҷҗеҲ¶] зҷ»еҪ•жЈҖжҹҘеӨұиҙҘ:', e);
        return true; // еӨұиҙҘж”ҫиЎҢ
    }
}

// жЈҖжҹҘи®ўйҳ…йҖҹзҺҮйҷҗеҲ¶пјҲ10ж¬Ў/е°Ҹж—¶пјү
async function жЈҖжҹҘи®ўйҳ…йҖҹзҺҮйҷҗеҲ¶(и®ҝй—®IP, env) {
    if (!env?.KV) return true;
    const key = `sub_rl:${и®ҝй—®IP}`;
    const now = Date.now();
    const windowMs = 60 * 60 * 1000; // 1е°Ҹж—¶
    try {
        const data = await env.KV.get(key, 'json') || { count: 0, resetAt: now + windowMs };
        if (now > data.resetAt) {
            data.count = 0;
            data.resetAt = now + windowMs;
        }
        if (data.count >= 10) return false;
        data.count++;
        await env.KV.put(key, JSON.stringify(data), { expirationTtl: 3600 });
        return true;
    } catch (e) {
        console.error('[йҖҹзҺҮйҷҗеҲ¶] и®ўйҳ…жЈҖжҹҘеӨұиҙҘ:', e);
        return true;
    }
}

// жЈҖжҹҘд»ЈзҗҶе№¶еҸ‘йҷҗеҲ¶пјҲ5е№¶еҸ‘/IPпјү
async function жЈҖжҹҘд»ЈзҗҶе№¶еҸ‘(и®ҝй—®IP, env) {
    if (!env?.KV) return true;
    const key = `proxy_conn:${и®ҝй—®IP}`;
    try {
        const current = parseInt(await env.KV.get(key) || '0');
        if (current >= 5) return false;
        await env.KV.put(key, String(current + 1), { expirationTtl: 300 });
        return true;
    } catch (e) {
        console.error('[йҖҹзҺҮйҷҗеҲ¶] д»ЈзҗҶе№¶еҸ‘жЈҖжҹҘеӨұиҙҘ:', e);
        return true;
    }
}

// йҮҠж”ҫд»ЈзҗҶе№¶еҸ‘и®Ўж•°
async function йҮҠж”ҫд»ЈзҗҶе№¶еҸ‘(и®ҝй—®IP, env) {
    if (!env?.KV) return;
    const key = `proxy_conn:${и®ҝй—®IP}`;
    try {
        const current = parseInt(await env.KV.get(key) || '0');
        if (current > 0) {
            await env.KV.put(key, String(current - 1), { expirationTtl: 300 });
        }
    } catch (e) {
        console.error('[йҖҹзҺҮйҷҗеҲ¶] йҮҠж”ҫе№¶еҸ‘еӨұиҙҘ:', e);
    }
}

// AES-128-CBC еҠ еҜҶеҮҪж•° (з”ЁдәҺи®ўйҳ…еҶ…е®№еҠ еҜҶ) - еҚҮзә§дёә SHA-256 еҜҶй’Ҙжҙҫз”ҹ
async function AESEncrypt(plaintext, password) {
    if (!plaintext || !password) return null;
    try {
        // дҪҝз”Ё SHA-256 жӣҝд»Ј MD5 иҝӣиЎҢеҜҶй’Ҙжҙҫз”ҹ
        const keyHash = await crypto.subtle.digest('SHA-256', SSж–Үжң¬зј–з ҒеҷЁ.encode(password));
        // еҸ–еүҚ 16 еӯ—иҠӮдҪңдёә AES-128 еҜҶй’Ҙ
        const keyBytes = new Uint8Array(keyHash).slice(0, 16);
        const iv = crypto.getRandomValues(new Uint8Array(16));
        const cryptoKey = await crypto.subtle.importKey(
            'raw',
            keyBytes,
            { name: 'AES-CBC', length: 128 },
            false,
            ['encrypt']
        );
        const encrypted = await crypto.subtle.encrypt(
            { name: 'AES-CBC', iv: iv },
            cryptoKey,
            SSж–Үжң¬зј–з ҒеҷЁ.encode(plaintext)
        );
        const result = new Uint8Array(iv.length + encrypted.byteLength);
        result.set(iv, 0);
        result.set(new Uint8Array(encrypted), iv.length);
        // зӣҙжҺҘеҜ№ Uint8Array еҒҡ Base64 зј–з ҒпјҢж— еӨ§е°ҸйҷҗеҲ¶
        return uint8ArrayToBase64(result);
    } catch (e) {
        console.error('AESеҠ еҜҶеӨұиҙҘ:', e);
        return null;
    }
}

// й«ҳжҖ§иғҪ Uint8Array вҶ’ Base64пјҢдёҚдҫқиө– btoa/String.fromCharCodeпјҢж— еӨ§е°ҸйҷҗеҲ¶
function uint8ArrayToBase64(bytes) {
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';
    const len = bytes.length;
    const parts = [];
    for (let i = 0; i < len; i += 3) {
        const b0 = bytes[i], b1 = i + 1 < len ? bytes[i + 1] : 0, b2 = i + 2 < len ? bytes[i + 2] : 0;
        parts.push(chars[b0 >> 2]);
        parts.push(chars[((b0 & 3) << 4) | (b1 >> 4)]);
        parts.push(i + 1 < len ? chars[((b1 & 15) << 2) | (b2 >> 6)] : '=');
        parts.push(i + 2 < len ? chars[b2 & 63] : '=');
    }
    return parts.join('');
}


function йҡҸжңәи·Ҝеҫ„(е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„ = "/") {
    const еёёз”Ёи·Ҝеҫ„зӣ®еҪ• = ["#","about","account","acg","act","activity","ad","admin","ads","ajax","album","albums","anime","api","app","apps","archive","archives","article","articles","ask","auth","avatar","bbs","bd","blog","blogs","book","books","bt","buy","cart","category","categories","cb","channel","channels","chat","china","city","class","classify","clip","clips","club","cn","code","collect","collection","comic","comics","community","company","config","contact","content","course","courses","cp","data","detail","details","dh","directory","discount","discuss","dl","dload","doc","docs","document","documents","doujin","download","downloads","drama","edu","en","ep","episode","episodes","event","events","f","faq","favorite","favourites","favs","feedback","file","files","film","films","forum","forums","friend","friends","game","games","gif","go","go.html","go.php","group","groups","help","home","hot","htm","html","image","images","img","index","info","intro","item","items","ja","jp","jump","jump.html","jump.php","jumping","knowledge","lang","lesson","lessons","lib","library","link","links","list","live","lives","login","logout","m","mag","magnet","mall","manhua","map","member","members","message","messages","mobile","movie","movies","music","my","new","news","note","novel","novels","online","order","out","out.html","out.php","outbound","p","page","pages","pay","payment","pdf","photo","photos","pic","pics","picture","pictures","play","player","playlist","post","posts","product","products","program","programs","project","qa","question","rank","ranking","read","readme","redirect","redirect.html","redirect.php","reg","register","res","resource","retrieve","sale","search","season","seasons","section","seller","series","service","services","setting","settings","share","shop","show","shows","site","soft","sort","source","special","star","stars","static","stock","store","stream","streaming","streams","student","study","tag","tags","task","teacher","team","tech","temp","t