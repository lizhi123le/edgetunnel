function и§ЈжһҗжңЁй©¬иҜ·жұӮ(buffer, passwordPlainText) {
    // еҠ ејәиҫ№з•ҢжЈҖжҹҘ
    if (!buffer || buffer.byteLength < 58) return { hasError: true, message: "invalid data: too short" };
    
    const sha224Password = sha224(passwordPlainText);
    let crLfIndex = 56;
    
