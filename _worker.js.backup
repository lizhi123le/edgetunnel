// ејӮжӯҘи¶…ж—¶еҢ…иЈ…еҷЁ - йҳІжӯўж— йҷҗзӯүеҫ…еҜјиҮҙ Worker жҢӮиө·
const withTimeout = (promise, timeoutMs = 5000, abortController = null) => {
    const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error('ж“ҚдҪңи¶…ж—¶')), timeoutMs));
    if (abortController) {
        // еҰӮжһңжҸҗдҫӣдәҶ AbortControllerпјҢи¶…ж—¶ж—¶д№ҹи§ҰеҸ‘ abort
        const timeoutId = setTimeout(() => {
            if (abortController && typeof abortController.abort === 'function') {
                try { abortController.abort(); } catch (e) { console.error('AbortController.abort failed:', e); }
            }
        }, timeoutMs);
        return Promise.race([promise, timeoutPromise]).finally(() => clearTimeout(timeoutId));
    }
    return Promise.race([promise, timeoutPromise]);
};

// Fetch и¶…ж—¶еҢ…иЈ…еҷЁ - йҳІжӯўеӨ–йғЁ API иҜ·жұӮж— йҷҗжҢӮиө·
// й”ҷиҜҜе“Қеә”е·Іжё…зҗҶпјҢдёҚиҝ”еӣһеҶ…йғЁз»ҶиҠӮз»ҷе®ўжҲ·з«Ҝ
const fetchWithTimeout = (url, options = {}, timeoutMs = 10000) => {
    const controller = new AbortController();
    const id = setTimeout(() => controller.abort(), timeoutMs);
    return fetch(url, { ...options, signal: controller.signal })
        .then(res => { 
            clearTimeout(id); 
            // жё…зҗҶй”ҷиҜҜе“Қеә”пјҡдёҚеҗ‘е®ўжҲ·з«Ҝжі„йңІеҶ…йғЁдҝЎжҒҜ
            if (!res.ok) {
                const зҠ¶жҖҒз Ғ = res.status;
                res = new Response(JSON.stringify({ error: `иҜ·жұӮеӨұиҙҘ (${зҠ¶жҖҒз Ғ})` }), {
                    status: зҠ¶жҖҒз Ғ,
                    headers: { 'Content-Type': 'application/json;charset=utf-8' }
                });
            }
            return res; 
        })
        .catch(err => { 
            clearTimeout(id); 
            // з»ҹдёҖй”ҷиҜҜе“Қеә”ж јејҸпјҢйҒҝе…Қжі„йңІе Ҷж ҲжҲ–еҶ…йғЁзҠ¶жҖҒ
            if (err.name === 'AbortError') {
                throw new Error('иҜ·жұӮи¶…ж—¶пјҢиҜ·зЁҚеҗҺйҮҚиҜ•');
            }
            throw new Error('зҪ‘з»ңиҜ·жұӮеӨұиҙҘпјҢиҜ·зЁҚеҗҺйҮҚиҜ•'); 
        });
};

