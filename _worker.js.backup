            }
        }
        const жҺ’еәҸеҗҺж•°з»„ = жүҖжңүеҸҚд»Јж•°з»„.sort((a, b) => a[0].localeCompare(b[0]));
        const зӣ®ж Үж №еҹҹеҗҚ = зӣ®ж ҮеҹҹеҗҚ.includes('.') ? зӣ®ж ҮеҹҹеҗҚ.split('.').slice(-2).join('.') : зӣ®ж ҮеҹҹеҗҚ;
