        );
        if (!configJSON || йҮҚзҪ®й…ҚзҪ® == true) {
            await withTimeout(
                env.KV.put('config.json', JSON.stringify(й»ҳи®Өй…ҚзҪ®JSON, null, 2)),
                3000
            );
            config_JSON = ctx2 ? (ctx2.config_JSON = й»ҳи®Өй…ҚзҪ®JSON) : й»ҳи®Өй…ҚзҪ®JSON;
        } else {
            config_JSON = ctx2 ? (ctx2.config_JSON = JSON.parse(configJSON)) : JSON.parse(configJSON);
        }
    } catch (error) {
        console.error(`иҜ»еҸ–config_JSONеҮәй”ҷ: ${error.message}`);
        config_JSON = ctx2 ? (ctx2.config_JSON = й»ҳи®Өй…ҚзҪ®JSON) : й»ҳи®Өй…ҚзҪ®JSON;
    }

    if (!config_JSON.gRPCUserAgent) config_JSON.gRPCUserAgent = UA;
    config_JSON.HOST = host;
    if (!config_JSON.HOSTS) config_JSON.HOSTS = [hostname];
    if (env.HOST) config_JSON.HOSTS = (await ж•ҙзҗҶжҲҗж•°з»„(env.HOST)).map(h => h.toLowerCase().replace(/^https?:\/\//, '').split('/')[0].split(':')[0]);
    config_JSON.UUID = userID;
    if (!config_JSON.йҡҸжңәи·Ҝеҫ„) config_JSON.йҡҸжңәи·Ҝеҫ„ = false;
    if (!config_JSON.еҗҜз”Ё0RTT) config_JSON.еҗҜз”Ё0RTT = false;

    if (env.PATH) config_JSON.PATH = env.PATH.startsWith('/') ? env.PATH : '/' + env.PATH;
    else if (!config_JSON.PATH) config_JSON.PATH = '/';

    if (!config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ?.[_p]) {
        config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ = {
            [_p]: "proxyip=" + еҚ дҪҚз¬Ұ,
            SOCKS5: {
                е…ЁеұҖ: "socks5://" + еҚ дҪҚз¬Ұ,
                ж ҮеҮҶ: "socks5=" + еҚ дҪҚз¬Ұ
            },
            HTTP: {
                е…ЁеұҖ: "http://" + еҚ дҪҚз¬Ұ,
                ж ҮеҮҶ: "http=" + еҚ дҪҚз¬Ұ
            },
            HTTPS: {
                е…ЁеұҖ: "https://" + еҚ дҪҚз¬Ұ,
                ж ҮеҮҶ: "https=" + еҚ дҪҚз¬Ұ
            },
        };
    }
    if (!config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ.HTTPS) config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ.HTTPS = { е…ЁеұҖ: "https://" + еҚ дҪҚз¬Ұ, ж ҮеҮҶ: "https=" + еҚ дҪҚз¬Ұ };

    const д»ЈзҗҶй…ҚзҪ® = config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ[config_JSON.еҸҚд»Ј.SOCKS5.еҗҜз”Ё?.toUpperCase()];

    let и·Ҝеҫ„еҸҚд»ЈеҸӮж•° = '';
    if (д»ЈзҗҶй…ҚзҪ® && config_JSON.еҸҚд»Ј.SOCKS5.иҙҰеҸ·) и·Ҝеҫ„еҸҚд»ЈеҸӮж•° = (config_JSON.еҸҚд»Ј.SOCKS5.е…ЁеұҖ ? д»ЈзҗҶй…ҚзҪ®.е…ЁеұҖ : д»ЈзҗҶй…ҚзҪ®.ж ҮеҮҶ).replace(еҚ дҪҚз¬Ұ, config_JSON.еҸҚд»Ј.SOCKS5.иҙҰеҸ·);
    else if (config_JSON.еҸҚд»Ј[_p] !== 'auto') и·Ҝеҫ„еҸҚд»ЈеҸӮж•° = config_JSON.еҸҚд»Ј.и·Ҝеҫ„жЁЎжқҝ[_p].replace(еҚ дҪҚз¬Ұ, config_JSON.еҸҚд»Ј[_p]);

    let еҸҚд»ЈжҹҘиҜўеҸӮж•° = '';
    if (и·Ҝеҫ„еҸҚд»ЈеҸӮж•°.includes('?')) {
        const [еҸҚд»Ји·Ҝеҫ„йғЁеҲҶ, еҸҚд»ЈжҹҘиҜўйғЁеҲҶ] = и·Ҝеҫ„еҸҚд»ЈеҸӮж•°.split('?');
        и·Ҝеҫ„еҸҚд»ЈеҸӮж•° = еҸҚд»Ји·Ҝеҫ„йғЁеҲҶ;
        еҸҚд»ЈжҹҘиҜўеҸӮж•° = еҸҚд»ЈжҹҘиҜўйғЁеҲҶ;
    }

    config_JSON.PATH = config_JSON.PATH.replace(и·Ҝеҫ„еҸҚд»ЈеҸӮж•°, '').replace('//', '/');
    const normalizedPath = config_JSON.PATH === '/' ? '' : config_JSON.PATH.replace(/\/+(?=\?|$)/, '').replace(/\/+$/, '');
    const [и·Ҝеҫ„йғЁеҲҶ, ...жҹҘиҜўж•°з»„] = normalizedPath.split('?');
    const жҹҘиҜўйғЁеҲҶ = жҹҘиҜўж•°з»„.length ? '?' + жҹҘиҜўж•°з»„.join('?') : '';
    const жңҖз»ҲжҹҘиҜўйғЁеҲҶ = еҸҚд»ЈжҹҘиҜўеҸӮж•° ? (жҹҘиҜўйғЁеҲҶ ? жҹҘиҜўйғЁеҲҶ + '&' + еҸҚд»ЈжҹҘиҜўеҸӮж•° : '?' + еҸҚд»ЈжҹҘиҜўеҸӮж•°) : жҹҘиҜўйғЁеҲҶ;
    config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„ = (и·Ҝеҫ„йғЁеҲҶ || '/') + (и·Ҝеҫ„йғЁеҲҶ && и·Ҝеҫ„еҸҚд»ЈеҸӮж•° ? '/' : '') + и·Ҝеҫ„еҸҚд»ЈеҸӮж•° + жңҖз»ҲжҹҘиҜўйғЁеҲҶ + (config_JSON.еҗҜз”Ё0RTT ? (жңҖз»ҲжҹҘиҜўйғЁеҲҶ ? '&' : '?') + 'ed=2560' : '');

    if (!config_JSON.TLSеҲҶзүҮ && config_JSON.TLSеҲҶзүҮ !== null) config_JSON.TLSеҲҶзүҮ = null;
    const TLSеҲҶзүҮеҸӮж•° = config_JSON.TLSеҲҶзүҮ == 'Shadowrocket' ? `&fragment=${encodeURIComponent('1,40-60,30-50,tlshello')}` : config_JSON.TLSеҲҶзүҮ == 'Happ' ? `&fragment=${encodeURIComponent('3,1,tlshello')}` : '';
    if (!config_JSON.Fingerprint) config_JSON.Fingerprint = "chrome";
    if (!config_JSON.ECH) config_JSON.ECH = false;
    if (!config_JSON.ECHConfig) config_JSON.ECHConfig = { DNS: CM_DoH, SNI: null };
    const ECH_SNI = (config_JSON.ECHConfig.SNI && config_JSON.ECHConfig.SNI !== 'auto') ? config_JSON.ECHConfig.SNI : йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(config_JSON.HOSTS[Math.floor(Math.random() * config_JSON.HOSTS.length)]);
    const ECHLINKеҸӮж•° = config_JSON.ECH ? `&ech=${encodeURIComponent(ECH_SNI + '+' + config_JSON.ECHConfig.DNS)}` : '';
    const SS_ECHеҸӮж•° = (config_JSON.ECH && config_JSON.SS.TLS === true && config_JSON.еҚҸи®®зұ»еһӢ === 'ss') ? `&echconfiglist=${encodeURIComponent(ECH_SNI + '+' + config_JSON.ECHConfig.DNS)}&fp=${config_JSON.Fingerprint}` : ECHLINKеҸӮж•°;

    const LINKдј иҫ“еҚҸи®® = config_JSON.дј иҫ“еҚҸи®® === 'xhttp' ? 'xhttp&mode=stream-one' : (config_JSON.дј иҫ“еҚҸи®® === 'grpc' ? (config_JSON.gRPCжЁЎејҸ === 'multi' ? 'grpc&mode=multi' : 'grpc&mode=gun') : 'ws');
    if (!config_JSON.SS) config_JSON.SS = { еҠ еҜҶж–№ејҸ: "aes-128-gcm", TLS: true };
    let LINKи·Ҝеҫ„еӯ—ж®өеҗҚ = 'path', LINKеҹҹеҗҚеӯ—ж®өеҗҚ = 'host';
    if (config_JSON.дј иҫ“еҚҸи®® === 'grpc') LINKи·Ҝеҫ„еӯ—ж®өеҗҚ = 'serviceName', LINKеҹҹеҗҚеӯ—ж®өеҗҚ = 'authority';
    config_JSON.LINK = config_JSON.еҚҸи®®зұ»еһӢ === 'ss'
        ? `${config_JSON.еҚҸи®®зұ»еһӢ}://${btoa(config_JSON.SS.еҠ еҜҶж–№ејҸ + ':' + userID)}@${host}:${config_JSON.SS.TLS ? '443' : '80'}?plugin=v2${encodeURIComponent(`ray-plugin;mode=websocket;host=${host};path=${((config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„.includes('?') ? config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„.replace('?', '?enc=' + config_JSON.SS.еҠ еҜҶж–№ејҸ + '&') : (config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„ + '?enc=' + config_JSON.SS.еҠ еҜҶж–№ејҸ)) + (config_JSON.SS.TLS ? ';tls' : ''))};mux=false`) + SS_ECHеҸӮж•°}#${encodeURIComponent(config_JSON.дјҳйҖүи®ўйҳ…з”ҹжҲҗ.SUBNAME)}`
        : `${config_JSON.еҚҸи®®зұ»еһӢ}://${userID}@${host}:443?security=tls&type=${LINKдј иҫ“еҚҸи®® + ECHLINKеҸӮж•°}&${LINKеҹҹеҗҚеӯ—ж®өеҗҚ}=${host}&fp=${config_JSON.Fingerprint}&sni=${host}&${LINKи·Ҝеҫ„еӯ—ж®өеҗҚ}=${encodeURIComponent(config_JSON.йҡҸжңәи·Ҝеҫ„ ? йҡҸжңәи·Ҝеҫ„(config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„) : config_JSON.е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„) + TLSеҲҶзүҮеҸӮж•°}&encryption=none${config_JSON.и·іиҝҮиҜҒд№ҰйӘҢиҜҒ ? '&insecure=1&allowInsecure=1' : ''}#${encodeURIComponent(config_JSON.дјҳйҖүи®ўйҳ…з”ҹжҲҗ.SUBNAME)}`;
    config_JSON.дјҳйҖүи®ўйҳ…з”ҹжҲҗ.TOKEN = await MD5MD5(hostname + userID);

    const еҲқе§ӢеҢ–TG_JSON = { BotToken: null, ChatID: null };
    config_JSON.TG = { еҗҜз”Ё: config_JSON.TG.еҗҜз”Ё ? config_JSON.TG.еҗҜз”Ё : false, ...еҲқе§ӢеҢ–TG_JSON };
    try {
        const TG_TXT = await withTimeout(env.KV.get('tg.json'), 3000);
        if (!TG_TXT) {
            await withTimeout(env.KV.put('tg.json', JSON.stringify(еҲқе§ӢеҢ–TG_JSON, null, 2)), 3000);
        } else {
            const TG_JSON = JSON.parse(TG_TXT);
            config_JSON.TG.ChatID = TG_JSON.ChatID ? TG_JSON.ChatID : null;
            config_JSON.TG.BotToken = TG_JSON.BotToken ? жҺ©з Ғж•Ҹж„ҹдҝЎжҒҜ(TG_JSON.BotToken) : null;
        }
    } catch (error) {
        console.error(`иҜ»еҸ–tg.jsonеҮәй”ҷ: ${error.message}`);
    }

    const еҲқе§ӢеҢ–CF_JSON = { Email: null, GlobalAPIKey: null, AccountID: null, APIToken: null, UsageAPI: null };
    config_JSON.CF = { ...еҲқе§ӢеҢ–CF_JSON, Usage: { success: false, pages: 0, workers: 0, total: 0, max: 100000 } };
    try {
        const CF_TXT = await withTimeout(env.KV.get('cf.json'), 3000);
        if (!CF_TXT) {
            await withTimeout(env.KV.put('cf.json', JSON.stringify(еҲқе§ӢеҢ–CF_JSON, null, 2)), 3000);
        } else {
            const CF_JSON = JSON.parse(CF_TXT);
            if (CF_JSON.UsageAPI) {
                try {
                    const response = await fetch(CF_JSON.UsageAPI);
                    const Usage = await response.json();
                    config_JSON.CF.Usage = Usage;
                } catch (err) {
                    console.error(`иҜ·жұӮ CF_JSON.UsageAPI еӨұиҙҘ: ${err.message}`);
                }
            } else {
                config_JSON.CF.Email = CF_JSON.Email ? CF_JSON.Email : null;
                config_JSON.CF.GlobalAPIKey = CF_JSON.GlobalAPIKey ? жҺ©з Ғж•Ҹж„ҹдҝЎжҒҜ(CF_JSON.GlobalAPIKey) : null;
                config_JSON.CF.AccountID = CF_JSON.AccountID ? жҺ©з Ғж•Ҹж„ҹдҝЎжҒҜ(CF_JSON.AccountID) : null;
                config_JSON.CF.APIToken = CF_JSON.APIToken ? жҺ©з Ғж•Ҹж„ҹдҝЎжҒҜ(CF_JSON.APIToken) : null;
                config_JSON.CF.UsageAPI = null;
                const Usage = await getCloudflareUsage(CF_JSON.Email, CF_JSON.GlobalAPIKey, CF_JSON.AccountID, CF_JSON.APIToken);
                config_JSON.CF.Usage = Usage;
            }
        }
    } catch (error) {
        console.error(`иҜ»еҸ–cf.jsonеҮәй”ҷ: ${error.message}`);
    }

    config_JSON.еҠ иҪҪж—¶й—ҙ = (performance.now() - еҲқе§ӢеҢ–ејҖе§Ӣж—¶й—ҙ).toFixed(2) + 'ms';
    // жӣҙж–°зј“еӯҳ
    configJSONCache = config_JSON;
    configJSONCacheKey = cacheKey;
    configJSONCacheTime = now;
    return config_JSON;
}

async function з”ҹжҲҗйҡҸжңәIP(request, count = 16, жҢҮе®ҡз«ҜеҸЈ = -1) {
    const ISPй…ҚзҪ® = {
        '9808': { file: 'cmcc', name: 'CFз§»еҠЁдјҳйҖү' },
        '4837': { file: 'cu', name: 'CFиҒ”йҖҡдјҳйҖү' },
        '17623': { file: 'cu', name: 'CFиҒ”йҖҡдјҳйҖү' },
        '17816': { file: 'cu', name: 'CFиҒ”йҖҡдјҳйҖү' },
        '4134': { file: 'ct', name: 'CFз”өдҝЎдјҳйҖү' },
    };
    const asn = request.cf?.asn, isp = ISPй…ҚзҪ®[asn];
    const cidr_url = isp ? `https://raw.githubusercontent.com/cmliu/cmliu/main/CF-CIDR/${isp.file}.txt` : 'https://raw.githubusercontent.com/cmliu/cmliu/main/CF-CIDR.txt';
    const cfname = isp?.name || 'CFе®ҳж–№дјҳйҖү';
    const cfport = [443, 2053, 2083, 2087, 2096, 8443];
    let cidrList = [];
    try { const res = await fetch(cidr_url); cidrList = res.ok ? await ж•ҙзҗҶжҲҗж•°з»„(await res.text()) : ['104.16.0.0/13']; } catch { cidrList = ['104.16.0.0/13']; }

    const generateRandomIPFromCIDR = (cidr) => {
        const [baseIP, prefixLength] = cidr.split('/'), prefix = parseInt(prefixLength), hostBits = 32 - prefix;
        const ipInt = baseIP.split('.').reduce((a, p, i) => a | (parseInt(p) << (24 - i * 8)), 0);
        const randomOffset = Math.floor(Math.random() * Math.pow(2, hostBits));
        const mask = (0xFFFFFFFF << hostBits) >>> 0, randomIP = (((ipInt & mask) >>> 0) + randomOffset) >>> 0;
        return [(randomIP >>> 24) & 0xFF, (randomIP >>> 16) & 0xFF, (randomIP >>> 8) & 0xFF, randomIP & 0xFF].join('.');
    };

    const randomIPs = Array.from({ length: count }, (_, index) => {
        const ip = generateRandomIPFromCIDR(cidrList[Math.floor(Math.random() * cidrList.length)]);
        return `${ip}:${жҢҮе®ҡз«ҜеҸЈ === -1 ? cfport[Math.floor(Math.random() * cfport.length)] : жҢҮе®ҡз«ҜеҸЈ}#${cfname}${index + 1}`;
    });
    return [randomIPs, randomIPs.join('\n')];
}

async function ж•ҙзҗҶжҲҗж•°з»„(еҶ…е®№) {
    var жӣҝжҚўеҗҺзҡ„еҶ…е®№ = еҶ…е®№.replace(/[	"'\r\n]+/g, ',').replace(/,+/g, ',');
    if (жӣҝжҚўеҗҺзҡ„еҶ…е®№.charAt(0) == ',') жӣҝжҚўеҗҺзҡ„еҶ…е®№ = жӣҝжҚўеҗҺзҡ„еҶ…е®№.slice(1);
    if (жӣҝжҚўеҗҺзҡ„еҶ…е®№.charAt(жӣҝжҚўеҗҺзҡ„еҶ…е®№.length - 1) == ',') жӣҝжҚўеҗҺзҡ„еҶ…е®№ = жӣҝжҚўеҗҺзҡ„еҶ…е®№.slice(0, жӣҝжҚўеҗҺзҡ„еҶ…е®№.length - 1);
    const ең°еқҖж•°з»„ = жӣҝжҚўеҗҺзҡ„еҶ…е®№.split(',');
    return ең°еқҖж•°з»„;
}

function isValidBase64(str) {
    if (typeof str !== 'string') return false;
    const cleanStr = str.replace(/\s/g, '');
    if (cleanStr.length === 0 || cleanStr.length % 4 !== 0) return false;
    const base64Regex = /^[A-Za-z0-9+/]+={0,2}$/;
    if (!base64Regex.test(cleanStr)) return false;
    try {
        atob(cleanStr);
        return true;
    } catch {
        return false;
    }
}

function base64Decode(str) {
    const bytes = new Uint8Array(atob(str).split('').map(c => c.charCodeAt(0)));
    const decoder = new TextDecoder('utf-8');
    return decoder.decode(bytes);
}

async function иҺ·еҸ–дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁж•°жҚ®(дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁHOST) {
    let дјҳйҖүIP = [], е…¶д»–иҠӮзӮ№LINK = '', ж јејҸеҢ–HOST = дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁHOST.replace(/^sub:\/\//i, 'https://').split('#')[0].split('?')[0];
    if (!/^https?:\/\//i.test(ж јејҸеҢ–HOST)) ж јејҸеҢ–HOST = `https://${ж јејҸеҢ–HOST}`;

    try {
        const url = new URL(ж јејҸеҢ–HOST);
        ж јејҸеҢ–HOST = url.origin;
    } catch (error) {
        дјҳйҖүIP.push(`127.0.0.1:1234#${дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁHOST}дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁж јејҸеҢ–ејӮеёё:${error.message}`);
        return [дјҳйҖүIP, е…¶д»–иҠӮзӮ№LINK];
    }

    const дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁURL = `${ж јејҸеҢ–HOST}/sub?host=example.com&uuid=00000000-0000-4000-8000-000000000000`;

    try {
        const response = await fetch(дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁURL, {
            headers: { 'User-Agent': 'v2rayN/edge' + 'tunnel (https://github.com/cmliu/edge' + 'tunnel)' }
        });

        if (!response.ok) {
            дјҳйҖүIP.push(`127.0.0.1:1234#${дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁHOST}дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁејӮеёё:${response.statusText}`);
            return [дјҳйҖүIP, е…¶д»–иҠӮзӮ№LINK];
        }

        const дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁиҝ”еӣһи®ўйҳ…еҶ…е®№ = atob(await response.text());
        const и®ўйҳ…иЎҢеҲ—иЎЁ = дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁиҝ”еӣһи®ўйҳ…еҶ…е®№.includes('\r\n')
            ? дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁиҝ”еӣһи®ўйҳ…еҶ…е®№.split('\r\n')
            : дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁиҝ”еӣһи®ўйҳ…еҶ…е®№.split('\n');

        for (const иЎҢеҶ…е®№ of и®ўйҳ…иЎҢеҲ—иЎЁ) {
            if (!иЎҢеҶ…е®№.trim()) continue; // и·іиҝҮз©әиЎҢ
            if (иЎҢеҶ…е®№.includes('00000000-0000-4000-8000-000000000000') && иЎҢеҶ…е®№.includes('example.com')) {
                // иҝҷжҳҜдјҳйҖүIPиЎҢпјҢжҸҗеҸ– еҹҹеҗҚ:з«ҜеҸЈ#еӨҮжіЁ
                const ең°еқҖеҢ№й…Қ = иЎҢеҶ…е®№.match(/:\/\/[^@]+@([^?]+)/);
                if (ең°еқҖеҢ№й…Қ) {
                    let ең°еқҖз«ҜеҸЈ = ең°еқҖеҢ№й…Қ[1], еӨҮжіЁ = ''; // еҹҹеҗҚ:з«ҜеҸЈ жҲ– IP:з«ҜеҸЈ
                    const еӨҮжіЁеҢ№й…Қ = иЎҢеҶ…е®№.match(/#(.+)$/);
                    if (еӨҮжіЁеҢ№й…Қ) еӨҮжіЁ = '#' + decodeURIComponent(еӨҮжіЁеҢ№й…Қ[1]);
                    дјҳйҖүIP.push(ең°еқҖз«ҜеҸЈ + еӨҮжіЁ);
                }
            } else {
                е…¶д»–иҠӮзӮ№LINK += иЎҢеҶ…е®№ + '\n';
            }
        }
    } catch (error) {
        дјҳйҖүIP.push(`127.0.0.1:1234#${дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁHOST}дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁејӮеёё:${error.message}`);
    }

    return [дјҳйҖүIP, е…¶д»–иҠӮзӮ№LINK];
}

async function иҜ·жұӮдјҳйҖүAPI(urls, й»ҳи®Өз«ҜеҸЈ = '443', и¶…ж—¶ж—¶й—ҙ = 8000) {
    if (!urls?.length) return [new Map(), [], []];
    const resultsMap = new Map();
    const еҸҚд»ЈIPжұ  = new Set();
    let йңҖиҰҒи®ўйҳ…иҪ¬жҚўи®ўйҳ…URLs = [];

    // еёҰйҮҚиҜ•зҡ„иҜ·жұӮиҫ…еҠ©еҮҪж•°
    const fetchWithRetry = async (url, maxRetries = 2) => {
        let lastError;
        for (let i = 0; i < maxRetries; i++) {
            try {
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), и¶…ж—¶ж—¶й—ҙ);
                const response = await fetch(url, { signal: controller.signal });
                clearTimeout(timeoutId);
                if (response.ok) return response;
                lastError = new Error(`HTTP ${response.status}`);
            } catch (e) {
                lastError = e;
                if (e.name === 'AbortError' || e.message?.includes('aborted')) {
                    await new Promise(r => setTimeout(r, 1000 + Math.random() * 270));
                    continue;
                }
                if (i < maxRetries - 1) {
                    await new Promise(r => setTimeout(r, 1000 + Math.random() * 270));
                }
            }
        }
        throw lastError;
    };

    await Promise.allSettled(urls.map(async (url) => {
        const urlResults = { IPs: [], Nodes: [] };
        resultsMap.set(url, urlResults);

        // жЈҖжҹҘURLжҳҜеҗҰеҢ…еҗ«еӨҮжіЁеҗҚ
        const hashIndex = url.indexOf('#');
        const urlWithoutHash = hashIndex > -1 ? url.substring(0, hashIndex) : url;
        const APIеӨҮжіЁеҗҚ = hashIndex > -1 ? decodeURIComponent(url.substring(hashIndex + 1)) : null;
        const дјҳйҖүIPдҪңдёәеҸҚд»ЈIP = url.toLowerCase().includes('proxyip=true');

        if (urlWithoutHash.toLowerCase().startsWith('sub://')) {
            try {
                const [дјҳйҖүIP, е…¶д»–иҠӮзӮ№LINK] = await иҺ·еҸ–дјҳйҖүи®ўйҳ…з”ҹжҲҗеҷЁж•°жҚ®(urlWithoutHash);
                // еӨ„зҗҶз¬¬дёҖдёӘж•°з»„ - дјҳйҖүIP
                if (APIеӨҮжіЁеҗҚ) {
                    for (const ip of дјҳйҖүIP) {
                        const еӨ„зҗҶеҗҺIP = ip.includes('#')
                            ? `${ip} [${APIеӨҮжіЁеҗҚ}]`
                            : `${ip}#[${APIеӨҮжіЁеҗҚ}]`;
                        urlResults.IPs.push(еӨ„зҗҶеҗҺIP);
                    }
                } else {
                    for (const ip of дјҳйҖүIP) {
                        urlResults.IPs.push(ip);
                        if (дјҳйҖүIPдҪңдёәеҸҚд»ЈIP) еҸҚд»ЈIPжұ .add(ip.split('#')[0]);
                    }
                }
                // еӨ„зҗҶз¬¬дәҢдёӘж•°з»„ - е…¶д»–иҠӮзӮ№LINK
                if (е…¶д»–иҠӮзӮ№LINK && typeof е…¶д»–иҠӮзӮ№LINK === 'string') {
                    let processedLink = е…¶д»–иҠӮзӮ№LINK;
                    if (APIеӨҮжіЁеҗҚ) {
                        processedLink = е…¶д»–иҠӮзӮ№LINK.replace(/([a-z][a-z0-9+\-.]*:\/\/[^\r\n]*?)(\r?\n|$)/gi, (match, link, lineEnd) => {
                            const е®Ңж•ҙй“ҫжҺҘ = link.includes('#')
                                ? `${link}${encodeURIComponent(` [${APIеӨҮжіЁеҗҚ}]`)}`
                                : `${link}${encodeURIComponent(`#[${APIеӨҮжіЁеҗҚ}]`)}`;
                            return `${е®Ңж•ҙй“ҫжҺҘ}${lineEnd}`;
                        });
                    }
                    urlResults.Nodes.push(...processedLink.split(/\r?\n/).filter(line => line.trim()));
                }
            } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
            return;
        }

        try {
            const response = await fetchWithRetry(urlWithoutHash);
            let text = '';
            try {
                const buffer = await response.arrayBuffer();
                const contentType = (response.headers.get('content-type') || '').toLowerCase();
                const charset = contentType.match(/charset=([^\s;]+)/i)?.[1]?.toLowerCase() || '';

                // ж №жҚ® Content-Type е“Қеә”еӨҙеҲӨж–ӯзј–з Ғдјҳе…Ҳзә§
                let decoders = ['utf-8', 'gb2312']; // й»ҳи®Өдјҳе…Ҳ UTF-8
                if (charset.includes('gb') || charset.includes('gbk') || charset.includes('gb2312')) {
                    decoders = ['gb2312', 'utf-8']; // еҰӮжһңжҳҺзЎ®жҢҮе®ҡ GB зі»зј–з ҒпјҢдјҳе…Ҳе°қиҜ• GB2312
                }

                // е°қиҜ•еӨҡз§Қзј–з Ғи§Јз Ғ
                let decodeSuccess = false;
                for (const decoder of decoders) {
                    try {
                        const decoded = new TextDecoder(decoder).decode(buffer);
                        // йӘҢиҜҒи§Јз Ғз»“жһңзҡ„жңүж•ҲжҖ§
                        if (decoded && decoded.length > 0 && !decoded.includes('\ufffd')) {
                            text = decoded;
                            decodeSuccess = true;
                            break;
                        } else if (decoded && decoded.length > 0) {
                            // еҰӮжһңжңүжӣҝжҚўеӯ—з¬Ұ (U+FFFD)пјҢиҜҙжҳҺзј–з ҒдёҚеҢ№й…ҚпјҢз»§з»ӯе°қиҜ•дёӢдёҖдёӘзј–з Ғ
                            continue;
                        }
                    } catch (e) {
                        // иҜҘзј–з Ғи§Јз ҒеӨұиҙҘпјҢе°қиҜ•дёӢдёҖдёӘ
                        continue;
                    }
                }

                // еҰӮжһңжүҖжңүзј–з ҒйғҪеӨұиҙҘжҲ–ж— ж•ҲпјҢе°қиҜ• response.text()
                if (!decodeSuccess) {
                    text = await response.text();
                }

                // еҰӮжһңиҝ”еӣһзҡ„жҳҜз©әжҲ–ж— ж•Ҳж•°жҚ®пјҢиҝ”еӣһ
                if (!text || text.trim().length === 0) {
                    return;
                }
            } catch (e) {
                console.error('Failed to decode response:', e);
                return;
            }

            const йў„еӨ„зҗҶи®ўйҳ…жҳҺж–ҮеҶ…е®№ = isValidBase64(text) ? base64Decode(text) : text;
            if (йў„еӨ„зҗҶи®ўйҳ…жҳҺж–ҮеҶ…е®№.split('#')[0].includes('://')) {
                // еӨ„зҗҶLINKеҶ…е®№
                let processedLink = йў„еӨ„зҗҶи®ўйҳ…жҳҺж–ҮеҶ…е®№;
                if (APIеӨҮжіЁеҗҚ) {
                    processedLink = йў„еӨ„зҗҶи®ўйҳ…жҳҺж–ҮеҶ…е®№.replace(/([a-z][a-z0-9+\-.]*:\/\/[^\r\n]*?)(\r?\n|$)/gi, (match, link, lineEnd) => {
                        const е®Ңж•ҙй“ҫжҺҘ = link.includes('#')
                            ? `${link}${encodeURIComponent(` [${APIеӨҮжіЁеҗҚ}]`)}`
                            : `${link}${encodeURIComponent(`#[${APIеӨҮжіЁеҗҚ}]`)}`;
                        return `${е®Ңж•ҙй“ҫжҺҘ}${lineEnd}`;
                    });
                }
                urlResults.Nodes.push(...processedLink.split(/\r?\n/).filter(line => line.trim()));
                return;
            }

            const lines = text.trim().split('\n').map(l => l.trim()).filter(l => l);
            const isCSV = lines.length > 1 && lines[0].includes(',');
            const IPV6_PATTERN = /^[^\[\]]*:[^\[\]]*:[^\[\]]/;
            const parsedUrl = new URL(urlWithoutHash);
            if (!isCSV) {
                lines.forEach(line => {
                    const lineHashIndex = line.indexOf('#');
                    const [hostPart, remark] = lineHashIndex > -1 ? [line.substring(0, lineHashIndex), line.substring(lineHashIndex)] : [line, ''];
                    let hasPort = false;
                    if (hostPart.startsWith('[')) {
                        hasPort = /\]:(\d+)$/.test(hostPart);
                    } else {
                        const colonIndex = hostPart.lastIndexOf(':');
                        hasPort = colonIndex > -1 && /^\d+$/.test(hostPart.substring(colonIndex + 1));
                    }
                    const port = parsedUrl.searchParams.get('port') || й»ҳи®Өз«ҜеҸЈ;
                    const ipItem = hasPort ? line : `${hostPart}:${port}${remark}`;
                    // еӨ„зҗҶз¬¬дёҖдёӘж•°з»„ - дјҳйҖүIP
                    if (APIеӨҮжіЁеҗҚ) {
                        const еӨ„зҗҶеҗҺIP = ipItem.includes('#')
                            ? `${ipItem} [${APIеӨҮжіЁеҗҚ}]`
                            : `${ipItem}#[${APIеӨҮжіЁеҗҚ}]`;
                        urlResults.IPs.push(еӨ„зҗҶеҗҺIP);
                    } else {
                        urlResults.IPs.push(ipItem);
                    }
                });
            } else {
                const headers = lines[0].split(',').map(h => h.trim());
                const dataLines = lines.slice(1);
                if (headers.includes('IPең°еқҖ') && headers.includes('з«ҜеҸЈ') && headers.includes('ж•°жҚ®дёӯеҝғ')) {
                    const ipIdx = headers.indexOf('IPең°еқҖ'), portIdx = headers.indexOf('з«ҜеҸЈ');
                    const remarkIdx = headers.indexOf('еӣҪе®¶') > -1 ? headers.indexOf('еӣҪе®¶') :
                        headers.indexOf('еҹҺеёӮ') > -1 ? headers.indexOf('еҹҺеёӮ') : headers.indexOf('ж•°жҚ®дёӯеҝғ');
                    const tlsIdx = headers.indexOf('TLS');
                    dataLines.forEach(line => {
                        const cols = line.split(',').map(c => c.trim());
                        if (tlsIdx !== -1 && cols[tlsIdx]?.toLowerCase() !== 'true') return;
                        const wrappedIP = IPV6_PATTERN.test(cols[ipIdx]) ? `[${cols[ipIdx]}]` : cols[ipIdx];
                        const ipItem = `${wrappedIP}:${cols[portIdx]}#${cols[remarkIdx]}`;
                        // еӨ„зҗҶз¬¬дёҖдёӘж•°з»„ - дјҳйҖүIP
                        if (APIеӨҮжіЁеҗҚ) {
                            const еӨ„зҗҶеҗҺIP = `${ipItem} [${APIеӨҮжіЁеҗҚ}]`;
                            urlResults.IPs.push(еӨ„зҗҶеҗҺIP);
                        } else {
                            urlResults.IPs.push(ipItem);
                        }
                    });
                } else if (headers.some(h => h.includes('IP')) && headers.some(h => h.includes('е»¶иҝҹ')) && headers.some(h => h.includes('дёӢиҪҪйҖҹеәҰ'))) {
                    const ipIdx = headers.findIndex(h => h.includes('IP'));
                    const delayIdx = headers.findIndex(h => h.includes('е»¶иҝҹ'));
                    const speedIdx = headers.findIndex(h => h.includes('дёӢиҪҪйҖҹеәҰ'));
                    const port = parsedUrl.searchParams.get('port') || й»ҳи®Өз«ҜеҸЈ;
                    dataLines.forEach(line => {
                        const cols = line.split(',').map(c => c.trim());
                        const wrappedIP = IPV6_PATTERN.test(cols[ipIdx]) ? `[${cols[ipIdx]}]` : cols[ipIdx];
                        const ipItem = `${wrappedIP}:${port}#CFдјҳйҖү ${cols[delayIdx]}ms ${cols[speedIdx]}MB/s`;
                        // еӨ„зҗҶз¬¬дёҖдёӘж•°з»„ - дјҳйҖүIP
                        if (APIеӨҮжіЁеҗҚ) {
                            const еӨ„зҗҶеҗҺIP = `${ipItem} [${APIеӨҮжіЁеҗҚ}]`;
                            urlResults.IPs.push(еӨ„зҗҶеҗҺIP);
                        } else {
                            urlResults.IPs.push(ipItem);
                        }
                    });
                }
            }
        } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
    }));

    return [resultsMap, йңҖиҰҒи®ўйҳ…иҪ¬жҚўи®ўйҳ…URLs, Array.from(еҸҚд»ЈIPжұ )];
}


async function еҸҚд»ЈеҸӮж•°иҺ·еҸ–(url, ctx2) {
    const { searchParams } = url, pathname = decodeURIComponent(url.pathname);
    const pathLower = pathname.toLowerCase();

    // еҲқе§ӢеҢ–
    жҲ‘зҡ„SOCKS5иҙҰеҸ· = ctx2.жҲ‘зҡ„SOCKS5иҙҰеҸ· = searchParams.get('socks5') || searchParams.get('http') || null;
    еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = searchParams.has('globalproxy') || false;

    // иҫ…еҠ©еҮҪж•°пјҡи§Јжһҗд»ЈзҗҶеҚҸи®®URL (socks5://... жҲ– http://...)
    const и§Јжһҗд»ЈзҗҶURL = (proxyUrl, й»ҳи®Өе…ЁеұҖ = true) => {
        const protocolMatch = proxyUrl.match(/^(socks5|http):\/\/(.+)$/i);
        if (!protocolMatch) return false;
        еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = protocolMatch[1].toLowerCase();
        жҲ‘зҡ„SOCKS5иҙҰеҸ· = ctx2.жҲ‘зҡ„SOCKS5иҙҰеҸ· = protocolMatch[2].split('/')[0];
        еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = й»ҳи®Өе…ЁеұҖ || ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј;
        return true;
    };

    // иҫ…еҠ©еҮҪж•°пјҡд»Һи·Ҝеҫ„еҖјдёӯжҸҗеҸ–е№ІеҮҖзҡ„ең°еқҖпјҲз§»йҷӨеҗҺз»ӯи·Ҝеҫ„ж®өпјү
    const жҸҗеҸ–и·Ҝеҫ„еҖј = (rawValue) => {
        if (rawValue.includes('://')) {
            // еҚҸи®®URLпјҡдҝқз•ҷ protocol://user:pass@host:portпјҢз§»йҷӨеҗҺз»ӯи·Ҝеҫ„
            const protocolPart = rawValue.split('://');
            if (protocolPart.length === 2) {
                const [protocol, afterProtocol] = protocolPart;
                const firstSlashIndex = afterProtocol.indexOf('/');
                if (firstSlashIndex > 0) {
                    return protocol + '://' + afterProtocol.substring(0, firstSlashIndex);
                }
            }
        } else {
            // жҷ®йҖҡIP:PORTпјҡеҸӘдҝқз•ҷеҲ°з¬¬дёҖдёӘ /
            const firstSlashIndex = rawValue.indexOf('/');
            if (firstSlashIndex > 0) {
                return rawValue.substring(0, firstSlashIndex);
            }
        }
        return rawValue;
    };

    // ==================== з¬¬дёҖжӯҘпјҡеӨ„зҗҶ query еҸӮж•° ====================
    // дјҳе…Ҳзә§жңҖй«ҳпјҡ?proxyip=, ?socks5=, ?http=
    let socksMatch, proxyMatch;
    if (searchParams.has('proxyip')) {
        const и·ҜеҸӮIP = searchParams.get('proxyip');
        // proxyip еҖјд»Ҙ socks5:// жҲ– http:// ејҖеӨҙпјҢи§ҶдёәеҜ№еә”еҚҸи®®еӨ„зҗҶ
        if (и§Јжһҗд»ЈзҗҶURL(и·ҜеҸӮIP)) { /* з»§з»ӯеҲ°дёӢж–№з»ҹдёҖи§Јжһҗ */ }
        else {
            // еҗҰеҲҷдҪңдёә IP еҸҚд»Ј
            еҸҚд»ЈIP = и·ҜеҸӮIP;
            еҗҜз”ЁеҸҚд»Је…ңеә• = false;
            return;
        }
    }
    // query дёӯзҡ„ ?socks5= е’Ң ?http= е·ІеңЁеҲқе§ӢеҢ–ж—¶з”ұ searchParams.get еӨ„зҗҶ

    // ==================== з¬¬дәҢжӯҘпјҡеӨ„зҗҶи·Ҝеҫ„дёӯзҡ„ SOCKS5/HTTP еҚҸи®®е…ій”®иҜҚ ====================
    // еҢ№й…Қпјҡ/socks5://..., /socks://.., /http://...
    else if ((socksMatch = pathname.match(/\/(socks5?|http):\/?\/?([^/?#\s]+)/i))) {
        еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = socksMatch[1].toLowerCase() === 'http' ? 'http' : 'socks5';
        жҲ‘зҡ„SOCKS5иҙҰеҸ· = ctx2.жҲ‘зҡ„SOCKS5иҙҰеҸ· = socksMatch[2].split('/')[0];
        еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = true;
    }
    // еҢ№й…Қпјҡ/socks5=..., /s5=..., /gs5=..., /http=..., /ghttp=...
    else if ((socksMatch = pathname.match(/\/(g?s5|socks5|g?http)=([^/?#\s]+)/i))) {
        const type = socksMatch[1].toLowerCase();
        жҲ‘зҡ„SOCKS5иҙҰеҸ· = ctx2.жҲ‘зҡ„SOCKS5иҙҰеҸ· = socksMatch[2].split('/')[0];
        еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = type.includes('http') ? 'http' : 'socks5';
        еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј = type.startsWith('g') || ctx2.еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј;
    }

    // ==================== з¬¬дёүжӯҘпјҡеӨ„зҗҶи·Ҝеҫ„дёӯзҡ„ proxyip/pyip/ip ====================
    else if ((proxyMatch = pathLower.match(/\/(proxyip[.=]|pyip=|ip=)([^?#\s]+)/))) {
        let и·ҜеҸӮIP = жҸҗеҸ–и·Ҝеҫ„еҖј(proxyMatch[2]);
        // proxyip еҖјд»Ҙ socks5:// жҲ– http:// ејҖеӨҙпјҢи§ҶдёәеҜ№еә”еҚҸи®®еӨ„зҗҶ
        if (!и§Јжһҗд»ЈзҗҶURL(и·ҜеҸӮIP)) {
            // еҗҰеҲҷдҪңдёә IP еҸҚд»Ј
            еҸҚд»ЈIP = ctx2.еҸҚд»ЈIP = и·ҜеҸӮIP;
            еҗҜз”ЁеҸҚд»Је…ңеә• = ctx2.еҗҜз”ЁеҸҚд»Је…ңеә• = false;
            return;
        }
    }

    // з»ҹдёҖи§ЈжһҗSOCKS5ең°еқҖ
    if (жҲ‘зҡ„SOCKS5иҙҰеҸ·) {
        try {
            parsedSocks5Address = ctx2.parsedSocks5Address = await иҺ·еҸ–SOCKS5иҙҰеҸ·(жҲ‘зҡ„SOCKS5иҙҰеҸ·);
            еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = searchParams.get('http') ? 'http' : (ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј || 'socks5');
        } catch (err) {
            console.error('и§ЈжһҗSOCKS5ең°еқҖеӨұиҙҘ:', err.message);
            еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = null;
        }
    } else еҗҜз”ЁSOCKS5еҸҚд»Ј = ctx2.еҗҜз”ЁSOCKS5еҸҚд»Ј = null;
}

async function иҺ·еҸ–SOCKS5иҙҰеҸ·(address) {
    if (address.includes('@')) {
        const lastAtIndex = address.lastIndexOf('@');
        let userPassword = address.substring(0, lastAtIndex).replaceAll('%3D', '=');
        const base64Regex = /^(?:[A-Z0-9+/]{4})*(?:[A-Z0-9+/]{2}==|[A-Z0-9+/]{3}=)?$/i;
        if (base64Regex.test(userPassword) && !userPassword.includes(':')) userPassword = atob(userPassword);
        address = `${userPassword}@${address.substring(lastAtIndex + 1)}`;
    }
    const atIndex = address.lastIndexOf("@");
    const [hostPart, authPart] = atIndex === -1 ? [address, undefined] : [address.substring(atIndex + 1), address.substring(0, atIndex)];

    // и§Јжһҗи®ӨиҜҒ
    let username, password;
    if (authPart) {
        [username, password] = authPart.split(":");
        if (!password) throw new Error('ж— ж•Ҳзҡ„ SOCKS ең°еқҖж јејҸпјҡи®ӨиҜҒйғЁеҲҶеҝ…йЎ»жҳҜ "username:password" зҡ„еҪўејҸ');
    }

    // и§Јжһҗдё»жңәз«ҜеҸЈ
    let hostname, port;
    if (hostPart.includes("]:")) { // IPv6еёҰз«ҜеҸЈ
        [hostname, port] = [hostPart.split("]:")[0] + "]", Number(hostPart.split("]:")[1].replace(/[^\d]/g, ''))];
    } else if (hostPart.startsWith("[")) { // IPv6ж— з«ҜеҸЈ
        [hostname, port] = [hostPart, 80];
    } else { // IPv4/еҹҹеҗҚ
        const parts = hostPart.split(":");
        [hostname, port] = parts.length === 2 ? [parts[0], Number(parts[1].replace(/[^\d]/g, ''))] : [hostPart, 80];
    }

    if (isNaN(port)) throw new Error('ж— ж•Ҳзҡ„ SOCKS ең°еқҖж јејҸпјҡз«ҜеҸЈеҸ·еҝ…йЎ»жҳҜж•°еӯ—');
    if (hostname.includes(":") && !/^\[.*\]$/.test(hostname)) throw new Error('ж— ж•Ҳзҡ„ SOCKS ең°еқҖж јејҸпјҡIPv6 ең°еқҖеҝ…йЎ»з”Ёж–№жӢ¬еҸ·жӢ¬иө·жқҘпјҢеҰӮ [2001:db8::1]');

    return { username, password, hostname, port };
}

async function getCloudflareUsage(Email, GlobalAPIKey, AccountID, APIToken) {
    const API = "https://api.cloudflare.com/client/v4";
    const sum = (a) => a?.reduce((t, i) => t + (i?.sum?.requests || 0), 0) || 0;
    const cfg = { "Content-Type": "application/json" };

    try {
        if (!AccountID && (!Email || !GlobalAPIKey)) return { success: false, pages: 0, workers: 0, total: 0, max: 100000 };

        if (!AccountID) {
            const r = await fetchWithTimeout(`${API}/accounts`, {
                method: "GET",
                headers: { ...cfg, "X-AUTH-EMAIL": Email, "X-AUTH-KEY": GlobalAPIKey }
            }, 10000);
            if (!r.ok) throw new Error(`иҙҰжҲ·иҺ·еҸ–еӨұиҙҘ: ${r.status}`);
            const d = await r.json();
            if (!d?.result?.length) throw new Error("жңӘжүҫеҲ°иҙҰжҲ·");
            const idx = d.result.findIndex(a => a.name?.toLowerCase().startsWith(Email.toLowerCase()));
            AccountID = d.result[idx >= 0 ? idx : 0]?.id;
        }

        const now = new Date();
        now.setUTCHours(0, 0, 0, 0);
        const hdr = APIToken ? { ...cfg, "Authorization": `Bearer ${APIToken}` } : { ...cfg, "X-AUTH-EMAIL": Email, "X-AUTH-KEY": GlobalAPIKey };

        const res = await fetchWithTimeout(`${API}/graphql`, {
            method: "POST",
            headers: hdr,
            body: JSON.stringify({
                query: `query getBillingMetrics($AccountID: String!, $filter: AccountWorkersInvocationsAdaptiveFilter_InputObject) {
                    viewer { accounts(filter: {accountTag: $AccountID}) {
                        pagesFunctionsInvocationsAdaptiveGroups(limit: 1000, filter: $filter) { sum { requests } }
                        workersInvocationsAdaptive(limit: 10000, filter: $filter) { sum { requests } }
                    } }
                }`,
                variables: { AccountID, filter: { datetime_geq: now.toISOString(), datetime_leq: new Date().toISOString() } }
            })
        });

        if (!res.ok) throw new Error(`жҹҘиҜўеӨұиҙҘ: ${res.status}`);
        const result = await res.json();
        if (result.errors?.length) throw new Error(result.errors[0].message);

        const acc = result?.data?.viewer?.accounts?.[0];
        if (!acc) throw new Error("жңӘжүҫеҲ°иҙҰжҲ·ж•°жҚ®");

        const pages = sum(acc.pagesFunctionsInvocationsAdaptiveGroups);
        const workers = sum(acc.workersInvocationsAdaptive);
        const total = pages + workers;
        const max = 100000;

        return { success: true, pages, workers, total, max };

    } catch (error) {
        console.error('иҺ·еҸ–дҪҝз”ЁйҮҸй”ҷиҜҜ:', error.message);
        return { success: false, pages: 0, workers: 0, total: 0, max: 100000 };
    }
}

function sha224(s) {
    const K = [0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5, 0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5, 0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3, 0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174, 0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc, 0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da, 0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7, 0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967, 0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13, 0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85, 0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3, 0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070, 0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5, 0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3, 0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208, 0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2];
    const r = (n, b) => ((n >>> b) | (n << (32 - b))) >>> 0;
    s = unescape(encodeURIComponent(s));
