        const statusLine = SSж–Үжң¬и§Јз ҒеҷЁ.decode(responseBuffer.slice(0, headerEndIndex)).split('\r\n')[0];
        const statusMatch = statusLine.match(/HTTP\/\d\.\d\s+(\d+)/);
        if (!statusMatch) throw new Error(`${HTTPSд»ЈзҗҶ ? 'HTTPS' : 'HTTP'} д»ЈзҗҶиҝ”еӣһж— ж•ҲзҠ¶жҖҒиЎҢ`);
        const statusCode = parseInt(statusMatch[1]);
        if (statusCode < 200 || statusCode >= 300) throw new Error(`${HTTPSд»ЈзҗҶ ? 'HTTPS' : 'HTTP'} д»ЈзҗҶиҝһжҺҘеӨұиҙҘ: ${statusCode}`);

        reader.releaseLock();
        if (жңүж•Ҳж•°жҚ®й•ҝеәҰ(initialData) > 0) {
            const initWriter = socket.writable.getWriter();
            await initWriter.write(initialData);
            initWriter.releaseLock();
        }
        return socket;
    } catch (error) {
        try { writer.releaseLock(); } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
