let SOCKS5白名单正则 = SOCKS5白名单.map(p => new RegExp(`^${p.replace(/\*/g, '.*')}$`, 'i'));
// 性能优化3: 预分配更大缓冲区（减少扩容）
const 预分配缓冲区大小 = 2048;
