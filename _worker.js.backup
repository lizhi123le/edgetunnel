            const grpcBridge = {
                readyState: WebSocket.OPEN,
                send(data) {
                    if (е·Іе…ій—ӯ) return;
                    const chunk = data instanceof Uint8Array ? data : new Uint8Array(data);
                    const lenBytesж•°з»„ = [];
                    let remaining = chunk.byteLength >>> 0;
                    while (remaining > 127) {
                        lenBytesж•°з»„.push((remaining & 0x7f) | 0x80);
