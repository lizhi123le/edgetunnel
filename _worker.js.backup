            const nameLen = (body[sniDataOffset + 3] << 8) | body[sniDataOffset + 4];
            if (nameLen === 0) return null;
            
            // SNI 名称在 body 中的位置
            const nameStartInBody = sniDataOffset + 5;
            if (nameStartInBody + nameLen > body.length) return null;
            
            const sniBytes = body.subarray(nameStartInBody, nameStartInBody + nameLen);
            const originalSNI = $decoder.decode(sniBytes);
            
