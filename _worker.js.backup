                        if (!payload.byteLength) continue;
                        if (isDnsQuery) {
                            if (判断是否是木马) await 转发木马UDP数据(payload, grpcBridge, 木马UDP上下文, ctx2);
                            else await forwardataudp(payload, grpcBridge, null, null, ctx2);
                            continue;
                        }
                        if (remoteConnWrapper.socket) {
                            // ★ 隐私增强：后续帧写入远端前剥离魔数+填充
