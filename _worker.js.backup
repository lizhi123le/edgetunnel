	const жҷ®йҖҡжөҒиҒҡеҗҲйҳҲеҖј = 128 * 1024, жҷ®йҖҡжөҒеҲ·ж–°й—ҙйҡ” = 2;
	const BYOBж…ўйҖҹеҲ·ж–°й—ҙйҡ” = 20, BYOBеҝ«йҖҹеҲ·ж–°й—ҙйҡ” = 2, BYOBе®үе…ЁйҳҲеҖј = BYOBзј“еҶІеҢәеӨ§е°Ҹ - BYOBеҚ•ж¬ЎиҜ»еҸ–дёҠйҷҗ;

