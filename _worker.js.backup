        TIME: new Date().toISOString(),
        HOST: host,
        HOSTS: [hostname],
        UUID: userID,
        PATH: "/",
        еҚҸи®®зұ»еһӢ: "v" + "le" + "ss",
        дј иҫ“еҚҸи®®: "ws",
        gRPCжЁЎејҸ: "gun",
        gRPCUserAgent: UA,
        и·іиҝҮиҜҒд№ҰйӘҢиҜҒ: false,
        еҗҜз”Ё0RTT: false,
        TLSеҲҶзүҮ: null,
