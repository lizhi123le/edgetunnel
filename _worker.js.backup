                if (队列字节数 >= 下行缓存上限) {
                    刷新发送队列();
                    return;
                }
                if (刷新Microtask已排队 || 刷新定时器) return;
                刷新Microtask已排队 = true;
                queueMicrotask(() => {
                    刷新Microtask已排队 = false;
                    if (已关闭 || 队列字节数 === 0 || 刷新定时器) return;
                    刷新定时器 = setTimeout(刷新发送队列, 下行刷新间隔);
                });
            };

