    }
    log(`[TCPиҪ¬еҸ‘] зӣ®ж Ү: ${host}:${portNum} | еҸҚд»ЈIP: ${еҸҚд»ЈIP} | еҸҚд»Је…ңеә•: ${еҗҜз”ЁеҸҚд»Је…ңеә• ? 'жҳҜ' : 'еҗҰ'} | еҸҚд»Јзұ»еһӢ: ${еҗҜз”ЁSOCKS5еҸҚд»Ј || 'proxyip'} | е…ЁеұҖ: ${еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј ? 'жҳҜ' : 'еҗҰ'}`);
