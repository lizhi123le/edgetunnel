                        const prefixes = data.replace(/\\010/g, ',').replace(/\n/g, ',').split(',').map(s => s.trim()).filter(Boolean);
                        жүҖжңүеҸҚд»Јж•°з»„.push(...prefixes.map(prefix => и§Јжһҗең°еқҖз«ҜеҸЈеӯ—з¬ҰдёІ(prefix)));
                    }
                } catch (error) {
