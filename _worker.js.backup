async function forwardataudp(udpChunk, webSocket, respHeader, е“Қеә”е°ҒиЈ…еҷЁ = null) {
    const иҜ·жұӮж•°жҚ® = ж•°жҚ®иҪ¬Uint8Array(udpChunk);
    const иҜ·жұӮеӯ—иҠӮж•° = иҜ·жұӮж•°жҚ®?.byteLength ?? иҜ·жұӮж•°жҚ®?.length ?? 0;
    log(`[UDP-DNS] ж”¶еҲ° DNS иҜ·жұӮ: ${иҜ·жұӮеӯ—иҠӮж•°}B -> 8.8.4.4:53`);
    try {
        const tcpSocket = connect({ hostname: '8.8.4.4', port: 53 });
        let йӯҸзғҲжҖқHeader = respHeader;
        const writer = tcpSocket.writable.getWriter();
        await writer.write(иҜ·жұӮж•°жҚ®);
