    let addressLength = 0;
    let addressIndex = 2;
    let address = "";
    
    switch (atype) {
        case 1: // IPv4
            addressLength = 4;
            if (socks5DataBuffer.byteLength < addressIndex + addressLength + 2) {
                return { hasError: true, message: "invalid S5 request: IPv4 data truncated" };
            }
            address = new Uint8Array(socks5DataBuffer.slice(addressIndex, addressIndex + addressLength)).join(".");
            break;
        case 3: // Domain
            addressLength = new Uint8Array(socks5DataBuffer.slice(addressIndex, addressIndex + 1))[0];
            if (addressLength === 0 || addressLength > 253) {
                return { hasError: true, message: "invalid S5 request: invalid domain length" };
            }
            addressIndex += 1;
            if (socks5DataBuffer.byteLength < addressIndex + addressLength + 2) {
                return { hasError: true, message: "invalid S5 request: domain data truncated" };
            }
            address = SSж–Үжң¬и§Јз ҒеҷЁ.decode(socks5DataBuffer.slice(addressIndex, addressIndex + addressLength));
            break;
        case 4: // IPv6
            addressLength = 16;
            if (socks5DataBuffer.byteLength < addressIndex + addressLength + 2) {
                return { hasError: true, message: "invalid S5 request: IPv6 data truncated" };
            }
            const dataView = new DataView(socks5DataBuffer.slice(addressIndex, addressIndex + addressLength));
            const ipv6 = [];
            for (let i = 0; i < 8; i++) {
                ipv6.push(dataView.getUint16(i * 2).toString(16));
            }
            address = ipv6.join(":");
            break;
        default:
            return { hasError: true, message: `invalid addressType is ${atype}` };
    }

    if (!address) {
        return { hasError: true, message: `address is empty, addressType is ${atype}` };
    }

    const portIndex = addressIndex + addressLength;
    if (portIndex + 2 > socks5DataBuffer.byteLength) {
        return { hasError: true, message: "invalid S5 request: port truncated" };
    }
    const portBuffer = socks5DataBuffer.slice(portIndex, portIndex + 2);
    const portRemote = new DataView(portBuffer).getUint16(0);

    return {
        hasError: false,
        addressType: atype,
        port: portRemote,
        hostname: address,
        rawClientData: socks5DataBuffer.slice(portIndex + 4)
    };
}

function и§ЈжһҗйӯҸзғҲжҖқиҜ·жұӮ(chunk, token) {
    // еҠ ејәиҫ№з•ҢжЈҖжҹҘ
    if (!chunk || chunk.byteLength < 24) return { hasError: true, message: 'Invalid data: too short' };
    
    const version = new Uint8Array(chunk.slice(0, 1));
    if (formatIdentifier(new Uint8Array(chunk.slice(1, 17))) !== token) return { hasError: true, message: 'Invalid uuid' };
    
    const optLen = new Uint8Array(chunk.slice(17, 18))[0];
    // жЈҖжҹҘ optLen жҳҜеҗҰжңүж•Ҳдё”иҫ№з•ҢжҳҜеҗҰи¶іеӨҹ
    if (optLen > 255) return { hasError: true, message: 'Invalid optLen' };
    if (chunk.byteLength < 19 + optLen + 1) return { hasError: true, message: 'Invalid data: truncated before command' };
    
    const cmd = new Uint8Array(chunk.slice(18 + optLen, 19 + optLen))[0];
    let isUDP = false;
    if (cmd === 1) { } else if (cmd === 2) { isUDP = true; } else { return { hasError: true, message: 'Invalid command' }; }
    
    const portIdx = 19 + optLen;
    if (portIdx + 2 > chunk.byteLength) return { hasError: true, message: 'Invalid data: port truncated' };
    const port = new DataView(chunk.slice(portIdx, portIdx + 2)).getUint16(0);
    if (port < 1 || port > 65535) return { hasError: true, message: `Invalid port: ${port}` };
    
    let addrIdx = portIdx + 2, addrLen = 0, addrValIdx = addrIdx + 1, hostname = '';
    if (addrIdx + 1 > chunk.byteLength) return { hasError: true, message: 'Invalid data: address type truncated' };
    
    const addressType = new Uint8Array(chunk.slice(addrIdx, addrValIdx))[0];
    switch (addressType) {
        case 1: // IPv4
            addrLen = 4;
            if (chunk.byteLength < addrValIdx + addrLen) {
                return { hasError: true, message: 'Invalid data: IPv4 truncated' };
            }
            hostname = new Uint8Array(chunk.slice(addrValIdx, addrValIdx + addrLen)).join('.');
            break;
        case 2: // Domain
            if (chunk.byteLength < addrValIdx + 1) {
                return { hasError: true, message: 'Invalid data: domain length truncated' };
            }
            addrLen = new Uint8Array(chunk.slice(addrValIdx, addrValIdx + 1))[0];
            if (addrLen === 0 || addrLen > 253) {
                return { hasError: true, message: 'Invalid domain length' };
            }
            addrValIdx += 1;
            if (chunk.byteLength < addrValIdx + addrLen) {
                return { hasError: true, message: 'Invalid data: domain truncated' };
            }
            hostname = SSж–Үжң¬и§Јз ҒеҷЁ.decode(chunk.slice(addrValIdx, addrValIdx + addrLen));
            break;
        case 3: // IPv6
            addrLen = 16;
            if (chunk.byteLength < addrValIdx + addrLen) {
                return { hasError: true, message: 'Invalid data: IPv6 truncated' };
            }
            const ipv6View = new DataView(chunk.slice(addrValIdx, addrValIdx + addrLen));
            const ipv6 = [];
            for (let i = 0; i < 8; i++) ipv6.push(ipv6View.getUint16(i * 2).toString(16));
            hostname = ipv6.join(':');
            break;
        default:
            return { hasError: true, message: `Invalid address type: ${addressType}` };
    }
    
    if (!hostname) return { hasError: true, message: `Invalid address: ${addressType}` };
    return { hasError: false, addressType, port, hostname, isUDP, rawIndex: addrValIdx + addrLen, version };
}

// SS (Shadowsocks) еҚҸи®®ж”ҜжҢҒ
const SSж”ҜжҢҒеҠ еҜҶй…ҚзҪ® = {
	'aes-128-gcm': {
