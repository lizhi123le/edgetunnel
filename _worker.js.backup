// ===== SNI 混合模块（服务器端真随机分发）=====
const 默认SNI白名单 = [
    'cn.bing.com',
    'www.iqiyi.com',
    'm.iqiyi.com',
    'www.bilibili.com',
    'www.youku.com',
    'www.taobao.com',
    'www.jd.com',
    'www.163.com',
    'www.sina.com.cn',
    'res.cdn.office.net',
    'static2.sharepointonline.com',
