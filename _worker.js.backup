","office","official","open","operation","opinion","option","order-detail","organization","overview","owner","package","partner","password","payment-info","people","performance","personal","phone","photo-gallery","plan","platform","policy","portal","portfolio","position","preferences","press-release","preview","pricing","print","privacy-policy","problem","process","profile-edit","project-detail","promotion","property","proposal","public","publication","purchase","quality","queue","quote","ranking-list","rate","rating","record","register-form","release","report","reporting","request","requirement","research","resource-center","response","result","resume","review","role","rule","sales","sample","schedule","school","score","screen","script","search-results","section-list","security","server","session","setting-page","setup","shop-cart","shopping","signin","signup-form","site-map","solution","staff","statistics","status-page","storage","store-front","studio","submission","subscribe-form","subscription","success","summary","support-center","survey","system","table","task-list","team-member","template","terms-of-service","test-case","ticket","timeline","toolbox","topic-list","tour","tracking-info","training","transaction","transfer","translation","tutorial","update","upgrade","upload-file","usage","user-guide","utility","validation","value","vendor","verification","version-info","visitor","voice","webmail","workflow"];
    const йҡҸжңәж•° = Math.floor(Math.random() * 3 + 1);
    const йҡҸжңәи·Ҝеҫ„ = еёёз”Ёи·Ҝеҫ„зӣ®еҪ•.sort(() => 0.5 - Math.random()).slice(0, йҡҸжңәж•°).join('/');
    if (е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„ === "/") return `/${йҡҸжңәи·Ҝеҫ„}`;
    else return `/${йҡҸжңәи·Ҝеҫ„ + е®Ңж•ҙиҠӮзӮ№и·Ҝеҫ„.replace('/?', '?')}`;
}

function йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(h) {
    if (!h?.includes('*')) return h;
    const еӯ—з¬ҰйӣҶ = 'abcdefghijklmnopqrstuvwxyz0123456789';
    return h.replace(/\*/g, () => {
        let s = '';
        for (let i = 0; i < Math.floor(Math.random() * 14) + 3; i++)
            s += еӯ—з¬ҰйӣҶ[Math.floor(Math.random() * 36)];
        return s;
    });
}

async function жү№йҮҸжӣҝжҚўеҹҹеҗҚ(еҶ…е®№, hosts, жҜҸз»„ж•°йҮҸ = 2) {
    const жү“д№ұеҗҺж•°з»„ = [...hosts].sort(() => Math.random() - 0.5);
    let count = 0;
    const parts = еҶ…е®№.split('example.com');
    if (parts.length <= 1) return еҶ…е®№;

    let result = parts[0];
    let currentRandomHost = null;
    let lastYieldTime = performance.now();
    for (let i = 1; i < parts.length; i++) {
        if (count % жҜҸз»„ж•°йҮҸ === 0) currentRandomHost = йҡҸжңәжӣҝжҚўйҖҡй…Қз¬Ұ(жү“д№ұеҗҺж•°з»„[Math.floor(count / жҜҸз»„ж•°йҮҸ) % жү“д№ұеҗҺж•°з»„.length]);
        count++;
        result += currentRandomHost + parts[i];
        if (performance.now() - lastYieldTime > 5) { await new Promise(r => setTimeout(r, 0)); lastYieldTime = performance.now(); }
    }
    return result;
}

async function ејӮжӯҘжү№йҮҸиҪ¬жҚўиҠӮзӮ№(ips, иҪ¬жҚўеҮҪж•°) {
    let result = [];
    let lastYieldTime = performance.now();
    for (let i = 0; i < ips.length; i++) {
        const node = иҪ¬жҚўеҮҪж•°(ips[i]);
        if (node) result.push(node);
        if (performance.now() - lastYieldTime > 5) { await new Promise(r => setTimeout(r, 0)); lastYieldTime = performance.now(); }
    }
    return result.join('\n');
}

async function DoHжҹҘиҜў(еҹҹеҗҚ, и®°еҪ•зұ»еһӢ, DoHи§ЈжһҗжңҚеҠЎ = "https://cloudflare-dns.com/dns-query") {
    const ејҖе§Ӣж—¶й—ҙ = performance.now();

    try {
        // и®°еҪ•зұ»еһӢеӯ—з¬ҰдёІиҪ¬ж•°еҖј
        const зұ»еһӢжҳ е°„ = { 'A': 1, 'NS': 2, 'CNAME': 5, 'MX': 15, 'TXT': 16, 'AAAA': 28, 'SRV': 33, 'HTTPS': 65 };
        const qtype = зұ»еһӢжҳ е°„[и®°еҪ•зұ»еһӢ.toUpperCase()] || 1;

        // зј–з ҒеҹҹеҗҚдёә DNS wire format labels
        const зј–з ҒеҹҹеҗҚ = (name) => {
            const parts = name.endsWith('.') ? name.slice(0, -1).split('.') : name.split('.');
            const bufs = [];
            for (const label of parts) {
                const enc = SSж–Үжң¬зј–з ҒеҷЁ.encode(label);
                bufs.push(new Uint8Array([enc.length]), enc);
            }
            bufs.push(new Uint8Array([0]));
            const total = bufs.reduce((s, b) => s + b.length, 0);
            const result = new Uint8Array(total);
            let off = 0;
            for (const b of bufs) { result.set(b, off); off += b.length; }
            return result;
        };

        // жһ„е»ә DNS жҹҘиҜўжҠҘж–Ү
        const qname = зј–з ҒеҹҹеҗҚ(еҹҹеҗҚ);
        const query = new Uint8Array(12 + qname.length + 4);
        const qview = new DataView(query.buffer);
        qview.setUint16(0, crypto.getRandomValues(new Uint16Array(1))[0]); // ID (random per RFC 1035)
        qview.setUint16(2, 0x0100);  // Flags: RD=1 (йҖ’еҪ’жҹҘиҜў)
        qview.setUint16(4, 1);       // QDCOUNT
        query.set(qname, 12);
        qview.setUint16(12 + qname.length, qtype);
        qview.setUint16(12 + qname.length + 2, 1); // QCLASS = IN

        // йҖҡиҝҮ POST еҸ‘йҖҒ dns-message иҜ·жұӮ

        const response = await fetchWithTimeout(DoHи§ЈжһҗжңҚеҠЎ, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/dns-message',
                'Accept': 'application/dns-message',
            },
            body: query,
        }, 5000);
        if (!response.ok) {

            return [];
        }

        // и§Јжһҗ DNS е“Қеә”жҠҘж–Ү
        const buf = new Uint8Array(await response.arrayBuffer());
        const dv = new DataView(buf.buffer);
        const qdcount = dv.getUint16(4);
        const ancount = dv.getUint16(6);


        // и§ЈжһҗеҹҹеҗҚпјҲеӨ„зҗҶжҢҮй’ҲеҺӢзј©пјү
        const и§ЈжһҗеҹҹеҗҚ = (pos) => {
            const labels = [];
            let p = pos, jumped = false, endPos = -1, safe = 128;
            while (p < buf.length && safe-- > 0) {
                const len = buf[p];
                if (len === 0) { if (!jumped) endPos = p + 1; break; }
                if ((len & 0xC0) === 0xC0) {
                    if (!jumped) endPos = p + 2;
                    p = ((len & 0x3F) << 8) | buf[p + 1];
                    jumped = true;
                    continue;
                }
                labels.push(SSж–Үжң¬и§Јз ҒеҷЁ.decode(buf.slice(p + 1, p + 1 + len)));
                p += len + 1;
            }
            if (endPos === -1) endPos = p + 1;
            return [labels.join('.'), endPos];
        };

        // и·іиҝҮ Question Section
        let offset = 12;
        for (let i = 0; i < qdcount; i++) {
            const [, end] = и§ЈжһҗеҹҹеҗҚ(offset);
            offset = /** @type {number} */ (end) + 4; // +4 и·іиҝҮ QTYPE + QCLASS
        }

        // и§Јжһҗ Answer Section
        const answers = [];
        for (let i = 0; i < ancount && offset < buf.length; i++) {
            const [name, nameEnd] = и§ЈжһҗеҹҹеҗҚ(offset);
            offset = /** @type {number} */ (nameEnd);
            const type = dv.getUint16(offset); offset += 2;
            offset += 2; // CLASS
            const ttl = dv.getUint32(offset); offset += 4;
            const rdlen = dv.getUint16(offset); offset += 2;
            const rdata = buf.slice(offset, offset + rdlen);
            offset += rdlen;

            let data;
            if (type === 1 && rdlen === 4) {
                // A и®°еҪ•
                data = `${rdata[0]}.${rdata[1]}.${rdata[2]}.${rdata[3]}`;
            } else if (type === 28 && rdlen === 16) {
                // AAAA и®°еҪ•
                const segs = [];
                for (let j = 0; j < 16; j += 2) segs.push(((rdata[j] << 8) | rdata[j + 1]).toString(16));
                data = segs.join(':');
            } else if (type === 16) {
                // TXT и®°еҪ• (й•ҝеәҰеүҚзјҖеӯ—з¬ҰдёІ)
                let tOff = 0;
                const parts = [];
                while (tOff < rdlen) {
                    const tLen = rdata[tOff++];
                    parts.push(SSж–Үжң¬и§Јз ҒеҷЁ.decode(rdata.slice(tOff, tOff + tLen)));
                    tOff += tLen;
                }
                data = parts.join('');
            } else if (type === 5) {
                // CNAME и®°еҪ•
                const [cname] = и§ЈжһҗеҹҹеҗҚ(offset - rdlen);
                data = cname;
            } else {
                data = Array.from(rdata).map(b => b.toString(16).padStart(2, '0')).join('');
            }
            answers.push({ name, type, TTL: ttl, data, rdata });
        }
        const иҖ—ж—¶ = (performance.now() - ејҖе§Ӣж—¶й—ҙ).toFixed(2);

        return answers;
    } catch (error) {
        const иҖ—ж—¶ = (performance.now() - ејҖе§Ӣж—¶й—ҙ).toFixed(2);
        console.error(`[DoHжҹҘиҜў] жҹҘиҜўеӨұиҙҘ ${еҹҹеҗҚ} ${и®°еҪ•зұ»еһӢ} via ${DoHи§ЈжһҗжңҚеҠЎ} ${иҖ—ж—¶}ms:`, error);
        return [];
    }
}

async function getECH(host) {
	if (ECH_CACHE.has(host)) return ECH_CACHE.get(host);
    try {
        const answers = await DoHжҹҘиҜў(host, 'HTTPS');
        if (!answers.length) return '';
        for (const ans of answers) {
            if (ans.type !== 65 || !ans.rdata) continue;
            const bytes = ans.rdata;
            // и§Јжһҗ SVCB/HTTPS rdata: SvcPriority(2) + TargetName(variable) + SvcParams
            let offset = 2; // и·іиҝҮ SvcPriority
            // и·іиҝҮ TargetName (еҹҹеҗҚзј–з Ғ)
            while (offset < bytes.length) {
                const len = bytes[offset];
                if (len === 0) { offset++; break; }
                offset += len + 1;
            }
            // йҒҚеҺҶ SvcParams й”®еҖјеҜ№
            while (offset + 4 <= bytes.length) {
                const key = (bytes[offset] << 8) | bytes[offset + 1];
                const len = (bytes[offset + 2] << 8) | bytes[offset + 3];
                offset += 4;
                // key=5 жҳҜ ECH (Encrypted Client Hello)
                if (key === 5) {
					const echConfig = btoa(String.fromCharCode(...bytes.slice(offset, offset + len)));
					ECH_CACHE.set(host, echConfig);
					return echConfig;
				}
                offset += len;
            }
        }
        return '';
    } catch {
        return '';
    }
}

async function иҜ»еҸ–config_JSON(env, hostname, userID, UA = "Mozilla/5.0", йҮҚзҪ®й…ҚзҪ® = false, ctx2 = null) {
    let config_JSON; // еЈ°жҳҺеұҖйғЁеҸҳйҮҸ
    // зҙ§жҖҘдјҳеҢ–пјҡзј“еӯҳ config_JSONпјҢйҒҝе…ҚжҜҸж¬ЎиҜ·жұӮйҮҚж–°з”ҹжҲҗпјҲжҢү host+userID зј“еӯҳпјү
    const cacheKey = `${hostname}:${userID}`;
    const now = Date.now();
    if (!йҮҚзҪ®й…ҚзҪ® && configJSONCacheKey === cacheKey && (now - configJSONCacheTime) < CONFIG_CACHE_TTL) {
