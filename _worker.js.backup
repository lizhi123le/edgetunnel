// 生成 Cookie 签名
async function generateCookieSignature(cookieValue, secret) {
    const key = await crypto.subtle.importKey(
        'raw',
        $encoder.encode(HMAC_SIGN_KEY_PREFIX + secret),
        { name: 'HMAC', hash: 'SHA-256' },
        false,
        ['sign']
    );
    const signature = await crypto.subtle.sign('HMAC', key, $encoder.encode(cookieValue));
    return btoa(String.fromCharCode(...new Uint8Array(signature))).replace(/=/g, '');
}

// 验证 Cookie 签名
async function verifyCookieSignature(cookieValue, signature, secret) {
    if (!cookieValue || !signature || !secret) return false;
    try {
        const expected = await generateCookieSignature(cookieValue, secret);
        const expectedBytes = $encoder.encode(expected);
        const providedBytes = $encoder.encode(signature);
        if (expectedBytes.length !== providedBytes.length) return false;
        return crypto.subtle.timingSafeEqual(expectedBytes, providedBytes);
    } catch (e) {
        console.warn('Cookie 签名验证异常:', e.message);
        return false;
    }
}

// 安全比较两个字符串（防时序攻击）
function secureCompare(a, b) {
    const aBytes = typeof a === 'string' ? $encoder.encode(a) : a;
    const bBytes = typeof b === 'string' ? $encoder.encode(b) : b;
    const maxLen = Math.max(aBytes.length, bBytes.length);
    // 填充到等长，避免泄露长度信息
    // 使用 0xFF 填充，避免与真实数据（可能为 0x00）碰撞
    const paddedA = new Uint8Array(maxLen).fill(0xFF);
    const paddedB = new Uint8Array(maxLen).fill(0xFF);
    paddedA.set(aBytes, 0);
    paddedB.set(bBytes, 0);
    return crypto.subtle.timingSafeEqual(paddedA, paddedB);
}

