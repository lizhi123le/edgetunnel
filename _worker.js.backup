                if (иҝңз«ҜеҶҷе…ҘеҷЁ) {
                    try { иҝңз«ҜеҶҷе…ҘеҷЁ.releaseLock(); } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
                    иҝңз«ҜеҶҷе…ҘеҷЁ = null;
                }
                еҪ“еүҚеҶҷе…ҘSocket = null;
                try { reader.releaseLock(); } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
            try { remoteConnWrapper.socket?.close(); } catch (e) { log(`[иө„жәҗжё…зҗҶ] е…ій—ӯиҝңзЁӢиҝһжҺҘеӨұиҙҘ: ${e.message}`); }
                try { controller.close(); } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
            };

            const йҮҠж”ҫиҝңз«ҜеҶҷе…ҘеҷЁ = () => {
                if (иҝңз«ҜеҶҷе…ҘеҷЁ) {
                    try { иҝңз«ҜеҶҷе…ҘеҷЁ.releaseLock(); } catch (e) { console.error(`[иө„жәҗжё…зҗҶ] ж“ҚдҪңеӨұиҙҘ: ${e.message}`); }
                    иҝңз«ҜеҶҷе…ҘеҷЁ = null;
                }
                еҪ“еүҚеҶҷе…ҘSocket = null;
            };

            const еҶҷе…Ҙиҝңз«Ҝ = async (payload, allowRetry = true) => {
                const socket = remoteConnWrapper.socket;
