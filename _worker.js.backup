    let еҪ“еүҚеҶҷе…ҘSocket = null;
    let иҝңз«ҜеҶҷе…ҘеҷЁ = null;
    //console.log('[gRPC] ејҖе§ӢеӨ„зҗҶеҸҢеҗ‘жөҒ');
    const grpcHeaders = new Headers({
        'Content-Type': 'application/grpc',
