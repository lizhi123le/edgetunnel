                    merged.set(еҪ“еүҚеқ—, pending.length);
                    pending = merged;
                    while (pending.byteLength >= 5) {
                        const grpcLen = ((pending[1] << 24) >>> 0) | (pending[2] << 16) | (pending[3] << 8) | pending[4];
                        const frameSize = 5 + grpcLen;
