			let flushй—ҙйҡ”жҜ«з§’ = BYOBеҝ«йҖҹеҲ·ж–°й—ҙйҡ”, flushе®ҡж—¶еҷЁ = null, зӯүеҫ…еҲ·ж–°жҒўеӨҚ = null;
			let жӯЈеңЁиҜ»еҸ– = false, иҜ»еҸ–дёӯеҫ…еҲ·ж–° = false;

			const flush = async () => {
				if (жӯЈеңЁиҜ»еҸ–) { иҜ»еҸ–дёӯеҫ…еҲ·ж–° = true; return }
				try {
					if (offset > 0) { const p = new Uint8Array(mainBuf.slice(0, offset)); offset = 0; await еҸ‘йҖҒеқ—(p) }
				} finally {
