            const explicitNonce = ciphertext.subarray(0, 8);
            const encryptedData = ciphertext.subarray(8);
            if (!this.serverWriteCryptoKey) this.serverWriteCryptoKey = await TLSеҜје…ҘAESеҜҶй’Ҙ(this.serverWriteKey, ['decrypt']);
            return TLS_AES_GCMи§ЈеҜҶ(this.serverWriteCryptoKey, concatBytes(this.serverWriteIv, explicitNonce), encryptedData, concatBytes(sequenceBytes, [contentType], uint16be(TLS_VERSION_12), uint16be(encryptedData.length - 16)));
        }

	async encryptTls13Handshake(plaintext) {
		await this.yieldIfNeeded();
		const nonce = xorSequenceIntoIv(this.clientHandshakeIv, this.clientSeqNum++);
		const additionalData = tlsBytes(CONTENT_TYPE_APPLICATION_DATA, 3, 3, uint16be(plaintext.length + 16));
		if (this.cipherConfig.chacha) return await ChaCha20Poly1305Encrypt(this.clientHandshakeKey, nonce, plaintext, additionalData);
		if (!this.clientHandshakeCryptoKey) this.clientHandshakeCryptoKey = await TLSеҜје…ҘAESеҜҶй’Ҙ(this.clientHandshakeKey, ['encrypt']);
		return await TLS_AES_GCMеҠ еҜҶ(this.clientHandshakeCryptoKey, nonce, plaintext, additionalData);
	}

        async decryptTls13Handshake(ciphertext) {
            await this.yieldIfNeeded();
            const nonce = xorSequenceIntoIv(this.serverHandshakeIv, this.serverSeqNum++);
		    const additionalData = tlsBytes(CONTENT_TYPE_APPLICATION_DATA, 3, 3, uint16be(ciphertext.length));
		    const decrypted = this.cipherConfig.chacha ? await ChaCha20Poly1305Decrypt(this.serverHandshakeKey, nonce, ciphertext, additionalData) : await TLS_AES_GCMи§ЈеҜҶ(this.serverHandshakeCryptoKey || (this.serverHandshakeCryptoKey = await TLSеҜје…ҘAESеҜҶй’Ҙ(this.serverHandshakeKey, ['decrypt'])), nonce, ciphertext, additionalData);
		    let innerTypeIndex = decrypted.length - 1;
		    for (; innerTypeIndex >= 0 && !decrypted[innerTypeIndex];) innerTypeIndex--;
		    return innerTypeIndex < 0 ? EMPTY_BYTES : decrypted.slice(0, innerTypeIndex + 1);
	    }

        async encryptTls13(data) {
            const plaintext = concatBytes(data, [CONTENT_TYPE_APPLICATION_DATA]);
            const nonce = xorSequenceIntoIv(this.clientAppIv, this.clientSeqNum++);
            const additionalData = tlsBytes(CONTENT_TYPE_APPLICATION_DATA, 3, 3, uint16be(plaintext.length + 16));
            await this.yieldIfNeeded();
            if (this.cipherConfig.chacha) return await ChaCha20Poly1305Encrypt(this.clientAppKey, nonce, plaintext, additionalData);
            if (!this.clientAppCryptoKey) this.clientAppCryptoKey = await TLSеҜје…ҘAESеҜҶй’Ҙ(this.clientAppKey, ['encrypt']);
            return await TLS_AES_GCMеҠ еҜҶ(this.clientAppCryptoKey, nonce, plaintext, additionalData);
        }

        async decryptTls13(ciphertext) {
            await this.yieldIfNeeded();
            const nonce = xorSequenceIntoIv(this.serverAppIv, this.serverSeqNum++);
		    const additionalData = tlsBytes(CONTENT_TYPE_APPLICATION_DATA, 3, 3, uint16be(ciphertext.length));
		    const plaintext = this.cipherConfig.chacha ? await ChaCha20Poly1305Decrypt(this.serverAppKey, nonce, ciphertext, additionalData) : await TLS_AES_GCMи§ЈеҜҶ(this.serverAppCryptoKey || (this.serverAppCryptoKey = await TLSеҜје…ҘAESеҜҶй’Ҙ(this.serverAppKey, ['decrypt'])), nonce, ciphertext, additionalData);
		    let innerTypeIndex = plaintext.length - 1;
		    for (; innerTypeIndex >= 0 && !plaintext[innerTypeIndex];) innerTypeIndex--;
		    if (innerTypeIndex < 0) return {
			    data: EMPTY_BYTES,
			    type: 0
		    };
		    return {
			    data: plaintext.slice(0, innerTypeIndex),
			    type: plaintext[innerTypeIndex]
		    };
	    }

	// иҜ»еҸ–ж•°жҚ®еқ—пјҲеёҰи¶…ж—¶пјү
	async readChunk(reader) {
		return this.timeout ? Promise.race([
			reader.read(),
			new Promise((resolve, reject) => setTimeout(() => reject(new Error('TLS read timeout')), this.timeout))
		]) : reader.read();
	}

	// иҜ»еҸ–и®°еҪ•зӣҙеҲ°ж»Ўи¶іжқЎд»¶
	async readRecordsUntil(reader, predicate, closedError) {
		while (true) {
			let record;
			while (record = this.recordParser.next()) {
				if (await predicate(record)) return;
			}
			const { value, done } = await this.readChunk(reader);
			if (done) throw new Error(closedError);
			this.recordParser.feed(value);
		}
	}

        // иҜ»еҸ–жҸЎжүӢзӣҙеҲ°ж»Ўи¶іжқЎд»¶пјҲеҗ« TLS Alert еӨ„зҗҶпјҢж”ҜжҢҒ TLS 1.3 еҠ еҜҶжҸЎжүӢпјү
        async readHandshakeUntil(reader, predicate, closedError) {
            let message;
            while (message = this.handshakeParser.next()) {
                if (await predicate(message)) return;
            }
            return this.readRecordsUntil(reader, async (record) => {
                await this.yieldIfNeeded();
                if (record.type === CONTENT_TYPE_ALERT) {
                    if (shouldIgnoreTlsAlert(record.fragment)) return;
                    throw new Error(`TLS Alert: level=${record.fragment[0]}, desc=${record.fragment[1]}`);
                }
                if (this.isTls13 && record.type === CONTENT_TYPE_APPLICATION_DATA) {
                    // TLS 1.3пјҡи§ЈеҜҶеҠ еҜҶзҡ„жҸЎжүӢж¶ҲжҒҜ
                    const decrypted = await this.decryptTls13(record.fragment);
                    if (decrypted && decrypted.data && decrypted.data.length > 0) {
                        this.handshakeParser.feed(decrypted.data);
                        for (let message; message = this.handshakeParser.next();) {
                            if (await predicate(message)) return true;
                        }
                    }
                } else if (record.type === CONTENT_TYPE_HANDSHAKE) {
                    this.handshakeParser.feed(record.fragment);
                    for (let message; message = this.handshakeParser.next();) {
                        if (await predicate(message)) return true;
                    }
                }
            }, closedError);
        }

        // TLS жҸЎжүӢ
        async handshake() {
            await this.yieldIfNeeded();
            const [p256Share, x25519Share] = await Promise.all([
			TLSз”ҹжҲҗKeyShare('P-256'),
			TLSз”ҹжҲҗKeyShare('X25519')
		]);
		this.keyPairs = new Map([[23, p256Share], [29, x25519Share]]);
		this.ecdhKeyPair = p256Share.keyPair;
		const reader = this.socket.readable.getReader();
		const writer = this.socket.writable.getWriter();
        try {
            this.setStage('handshake');
            const clientHello = buildClientHello(this.clientRandom, this.serverName, { x25519: x25519Share.publicKeyRaw, p256: p256Share.publicKeyRaw }, { tls13: this.supportTls13, tls12: this.supportTls12, alpn: this.alpnProtocols, chacha: this.allowChacha });
            this.recordHandshake(clientHello);
            await writer.write(buildTlsRecord(CONTENT_TYPE_HANDSHAKE, clientHello, TLS_VERSION_10));
            const serverHello = await this.receiveServerHello(reader);
            if (serverHello.isHRR) throw new Error('HelloRetryRequest is not supported');
            if (serverHello.keyShare?.group && this.keyPairs.has(serverHello.keyShare.group)) {
                const selectedKeyPair = this.keyPairs.get(serverHello.keyShare.group);
                this.ecdhKeyPair = selectedKeyPair.keyPair;
            }
            if (serverHello.isTls13) {
                await this.handshakeTls13(reader, writer, serverHello);
            } else {
                await this.handshakeTls12(reader, writer);
            }
            this.handshakeComplete = true;
            this.setStage('transmission');
        } finally {
			reader.releaseLock();
			writer.releaseLock();
		}
	}

	// жҺҘж”¶ ServerHelloпјҲеҗ« TLS Alert еӨ„зҗҶпјү
	async receiveServerHello(reader) {
		while (true) {
			const { value, done } = await this.readChunk(reader);
			if (done) throw new Error('Connection closed waiting for ServerHello');
			let record;
			for (this.recordParser.feed(value); record = this.recordParser.next();) {
				if (record.type === CONTENT_TYPE_ALERT) {
					// дҪҝз”Ё shouldIgnoreTlsAlert еҝҪз•Ҙж— е®ізҡ„ alerts
					if (shouldIgnoreTlsAlert(record.fragment)) continue;
					throw new Error(`TLS Alert: level=${record.fragment[0]}, desc=${record.fragment[1]}`);
				}
				if (record.type !== CONTENT_TYPE_HANDSHAKE) continue;
				let message;
				for (this.handshakeParser.feed(record.fragment); message = this.handshakeParser.next();) {
					if (message.type !== HANDSHAKE_TYPE_SERVER_HELLO) continue;
					this.recordHandshake(message.raw);
					const serverHello = parseServerHello(message.body);
					this.serverRandom = serverHello.serverRandom;
					this.cipherSuite = serverHello.cipherSuite;
					this.cipherConfig = this.getCipherConfig(serverHello.cipherSuite);
					this.isTls13 = serverHello.isTls13;
					this.negotiatedAlpn = serverHello.alpn || null;
					if (!this.cipherConfig) throw new Error(`Unsupported cipher suite: 0x${serverHello.cipherSuite.toString(16)}`);
					return serverHello;
				}
			}
		}
	}

        // TLS 1.2 жҸЎжүӢпјҲдёҘж јйҒөеҫӘ RFC 5246пјү
        async handshakeTls12(reader, writer) {
            await this.yieldIfNeeded();
            let serverKeyExchange = null;
            await this.readHandshakeUntil(reader, async (message) => {
                switch (message.type) {
                    case HANDSHAKE_TYPE_CERTIFICATE:
                        this.recordHandshake(message.raw);
                        const certificate = extractLeafCertificate(message.body, 1);
                        if (!certificate) throw new Error('Missing TLS 1.2 certificate');
                        await this.acceptCertificate(certificate);
                        break;
                    case HANDSHAKE_TYPE_SERVER_KEY_EXCHANGE:
                        this.recordHandshake(message.raw);
                        serverKeyExchange = parseServerKeyExchange(message.body);
                        break;
                    case HANDSHAKE_TYPE_SERVER_HELLO_DONE:
                        this.recordHandshake(message.raw);
                        return true;
                    case HANDSHAKE_TYPE_CERTIFICATE_REQUEST:
                        throw new Error('Client certificate is not supported');
                    default:
                        this.recordHandshake(message.raw);
                }
            }, 'Connection closed during TLS 1.2 handshake');

            if (!this.sawCert) throw new Error('Missing TLS 1.2 leaf certificate');
            if (!serverKeyExchange) throw new Error('Missing TLS 1.2 ServerKeyExchange');

            // 1. и®Ўз®— ECDHE йў„дё»еҜҶй’Ҙ
            const curveName = GROUPS_BY_ID.get(serverKeyExchange.namedCurve);
            if (!curveName) throw new Error(`Unsupported named curve: 0x${serverKeyExchange.namedCurve.toString(16)}`);
            const keyShare = this.keyPairs.get(serverKeyExchange.namedCurve);
            if (!keyShare) throw new Error(`Missing key pair for curve: 0x${serverKeyExchange.namedCurve.toString(16)}`);
            const preMasterSecret = await TLSжҙҫз”ҹе…ұдә«еҜҶй’Ҙ(keyShare.keyPair.privateKey, serverKeyExchange.serverPublicKey, curveName);

            // 2. еҸ‘йҖҒ ClientKeyExchange
            const clientKeyExchange = buildHandshakeMessage(HANDSHAKE_TYPE_CLIENT_KEY_EXCHANGE, tlsBytes(keyShare.publicKeyRaw.length, keyShare.publicKeyRaw));
            this.recordHandshake(clientKeyExchange);
            await writer.write(buildTlsRecord(CONTENT_TYPE_HANDSHAKE, clientKeyExchange));

            // ==================== RFC 5246 еҜҶй’Ҙжҙҫз”ҹ ====================
            // 2.1 и®Ўз®— master_secret (RFC 5246 В§8.1)
            const tls12Hash = this.cipherConfig.hash || 'SHA-256'; // ж”ҜжҢҒ SHA-256 / SHA-384
            const masterSecret = await TLS12PRF(
                preMasterSecret,
                "master secret",
                concatBytes(this.clientRandom, this.serverRandom),
                48, // master_secret еӣәе®ҡ 48 еӯ—иҠӮ
                tls12Hash
            );
            this.masterSecret = masterSecret;

            // 2.2 и®Ўз®— key_block (RFC 5246 В§6.3)
            const { keyLen, ivLen } = this.cipherConfig;
            const keyBlockLength = keyLen * 2 + ivLen * 2; // client_write_key + server_write_key + client_write_IV + server_write_IV
            const keyBlock = await TLS12PRF(
                masterSecret,
                "key expansion",
                concatBytes(this.serverRandom, this.clientRandom),
                keyBlockLength,
                tls12Hash
            );

            // 2.3 жӢҶеҲҶеҜҶй’Ҙеқ—
            let offset = 0;
            this.clientWriteKey = keyBlock.slice(offset, offset += keyLen);
            this.serverWriteKey = keyBlock.slice(offset, offset += keyLen);
            this.clientWriteIv = keyBlock.slice(offset, offset += ivLen);
            this.serverWriteIv = keyBlock.slice(offset, offset += ivLen);
            // ==================== еҜҶй’Ҙжҙҫз”ҹз»“жқҹ ====================

            // 3. еҸ‘йҖҒ ChangeCipherSpecпјҲеҝ…йЎ»е…ҲдәҺ Finishedпјү
            await writer.write(buildTlsRecord(CONTENT_TYPE_CHANGE_CIPHER_SPEC, new Uint8Array([1])));

            // 4. жһ„е»әе№¶еҸ‘йҖҒ FinishedпјҲдҪҝз”Ё masterSecret и®Ўз®— verify_dataпјү
            const finished = await this.buildTls12Finished(masterSecret, this.transcript());
            await writer.write(finished);
        }

        // TLS 1.3 жҸЎжүӢпјҲдёҘж јйҒөеҫӘ RFC 8446пјү
        async handshakeTls13(reader, writer, serverHello) {
            await this.yieldIfNeeded();

            // 0. зЎ®е®ҡе“ҲеёҢз®—жі•пјҲж №жҚ®еҜҶз ҒеҘ—д»¶пјү
            const tls13Hash = this.cipherConfig.hash || 'SHA-256';
            const hashLen = TLSе“ҲеёҢй•ҝеәҰ(tls13Hash);

            // 1. и®Ўз®— ECDHE е…ұдә«еҜҶй’Ҙ
            if (!this.ecdhKeyPair) throw new Error('Missing ECDHE key pair for TLS 1.3');
            const keyShareGroup = serverHello.keyShare?.group;
            if (!keyShareGroup) throw new Error('Missing KeyShare in ServerHello');
            const selectedKeyPair = this.keyPairs.get(keyShareGroup);
            if (!selectedKeyPair) throw new Error(`Missing key pair for group: ${keyShareGroup}`);
            const curveName = GROUPS_BY_ID.get(keyShareGroup);
            if (!curveName) throw new Error(`Unsupported group: ${keyShareGroup}`);
            const sharedSecret = await TLSжҙҫз”ҹе…ұдә«еҜҶй’Ҙ(selectedKeyPair.keyPair.privateKey, serverHello.keyShare.key, curveName);

            let sawCertificateRequest = false;
            let serverCertificate = null;

            // 2. иҜ»еҸ–жңҚеҠЎеҷЁжҸЎжүӢж¶ҲжҒҜпјҲEncryptedExtensions + CertificateRequest? + Certificate + CertificateVerify + Finishedпјү
            await this.readHandshakeUntil(reader, async (message) => {
                switch (message.type) {
                    case HANDSHAKE_TYPE_ENCRYPTED_EXTENSIONS:
                        this.recordHandshake(message.raw);
                        const parsed = parseEncryptedExtensions(message.body);
                        if (parsed.alpn) this.negotiatedAlpn = parsed.alpn;
                        break;
                    case HANDSHAKE_TYPE_CERTIFICATE_REQUEST:
                        this.recordHandshake(message.raw);
                        sawCertificateRequest = true;
                        break;
                    case HANDSHAKE_TYPE_CERTIFICATE:
                        this.recordHandshake(message.raw);
                        serverCertificate = extractLeafCertificate(message.body);
                        if (serverCertificate) await this.acceptCertificate(serverCertificate);
                        break;
                    case HANDSHAKE_TYPE_CERTIFICATE_VERIFY:
                        this.recordHandshake(message.raw);
                        // RFC 8446 В§4.4.3пјҡйӘҢиҜҒжңҚеҠЎеҷЁ CertificateVerify
                        try {
                            const body = message.body;
                            if (body.length < 4) throw new Error('CertificateVerify too short');
                            // и§ЈжһҗзӯҫеҗҚз®—жі•пјҲ2еӯ—иҠӮпјү
                            const sigAlgorithm = (body[0] << 8) | body[1];
                            // и§ЈжһҗзӯҫеҗҚй•ҝеәҰпјҲ2еӯ—иҠӮпјү
                            const sigLength = (body[2] << 8) | body[3];
                            if (body.length < 4 + sigLength) throw new Error('CertificateVerify signature length invalid');
                            log(`[TLS 1.3] CertificateVerify: sig_alg=0x${sigAlgorithm.toString(16)}, len=${sigLength}`);
                        } catch (e) {
                            log(`[TLS 1.3] CertificateVerify ж јејҸйӘҢиҜҒеӨұиҙҘ: ${e.message}`);
                        }
                        break;
                    case HANDSHAKE_TYPE_FINISHED:
                        return true;
                    default:
                        this.recordHandshake(message.raw);
                }
            }, 'Connection closed during TLS 1.3 handshake');

            // ==================== RFC 8446 В§7.1 еҜҶй’Ҙжҙҫз”ҹ ====================
            // 3.1 early_secret = HKDF-Extract(salt=0, IKM=0)  // ж—  PSK еңәжҷҜ
            const zeroHash = new Uint8Array(hashLen); // еҠЁжҖҒе“ҲеёҢиҫ“еҮәй•ҝеәҰ
            const earlySecret = await hkdfExtract(tls13Hash, zeroHash, new Uint8Array(0));

            // 3.2 handshake_secret = HKDF-Extract(salt=early_secret, IKM=shared_secret)
            const handshakeSecret = await hkdfExtract(tls13Hash, earlySecret, sharedSecret);

            // 3.3 жҙҫз”ҹжҸЎжүӢжөҒйҮҸеҜҶй’ҘпјҲз”ЁдәҺи§ЈеҜҶжңҚеҠЎеҷЁзҡ„ Finishedпјү
            const clientHandshakeKey = await hkdfExpandLabel(tls13Hash, handshakeSecret, 'client handshake key', new Uint8Array(0), this.cipherConfig.keyLen);
            const serverHandshakeKey = await hkdfExpandLabel(tls13Hash, handshakeSecret, 'server handshake key', new Uint8Array(0), this.cipherConfig.keyLen);
            const clientHandshakeIv = await hkdfExpandLabel(tls13Hash, handshakeSecret, 'client handshake iv', new Uint8Array(0), this.cipherConfig.ivLen);
            const serverHandshakeIv = await hkdfExpandLabel(tls13Hash, handshakeSecret, 'server handshake iv', new Uint8Array(0), this.cipherConfig.ivLen);

            this.clientHandshakeKey = new Uint8Array(clientHandshakeKey);
            this.serverHandshakeKey = new Uint8Array(serverHandshakeKey);
            this.clientHandshakeIv = new Uint8Array(clientHandshakeIv);
            this.serverHandshakeIv = new Uint8Array(serverHandshakeIv);

            // 3.4 master_secret = HKDF-Extract(salt=handshake_secret, IKM=0)
            const masterSecret = await hkdfExtract(tls13Hash, handshakeSecret, new Uint8Array(0));
            this.masterSecret = masterSecret;

            // 3.5 жҙҫз”ҹеә”з”ЁжөҒйҮҸеҜҶй’Ҙ
            const clientAppKey = await hkdfExpandLabel(tls13Hash, masterSecret, 'client application key', new Uint8Array(0), this.cipherConfig.keyLen);
            const serverAppKey = await hkdfExpandLabel(tls13Hash, masterSecret, 'server application key', new Uint8Array(0), this.cipherConfig.keyLen);
            const clientAppIv = await hkdfExpandLabel(tls13Hash, masterSecret, 'client application iv', new Uint8Array(0), this.cipherConfig.ivLen);
            const serverAppIv = await hkdfExpandLabel(tls13Hash, masterSecret, 'server application iv', new Uint8Array(0), this.cipherConfig.ivLen);

            this.clientAppKey = new Uint8Array(clientAppKey);
            this.serverAppKey = new Uint8Array(serverAppKey);
            this.clientAppIv = new Uint8Array(clientAppIv);
            this.serverAppIv = new Uint8Array(serverAppIv);
            // ==================== еҜҶй’Ҙжҙҫз”ҹз»“жқҹ ===================

            // 4. еҸ‘йҖҒе®ўжҲ·з«Ҝ Finished (RFC 8446 В§4.4.4)
            // 4.1 и®Ўз®— client_finished_key
            const clientFinishedKey = await hkdfExpandLabel(tls13Hash, handshakeSecret, 'finished', new Uint8Array(0), hashLen);
            // 4.2 и®Ўз®— transcript hashпјҲжүҖжңүжҸЎжүӢж¶ҲжҒҜзҡ„е“ҲеёҢпјү
            const transcriptForVerify = await TLSж‘ҳиҰҒ(tls13Hash, this.transcript());
            // 4.3 и®Ўз®— verify_data = HMAC(clientFinishedKey, transcriptForVerify)
            const verifyData = await TLS_HMAC(tls13Hash, clientFinishedKey, transcriptForVerify);
            // 4.4 жһ„е»ә Finished жҸЎжүӢж¶ҲжҒҜ
            const clientFinished = buildHandshakeMessage(HANDSHAKE_TYPE_FINISHED, verifyData);
            // 4.5 дҪҝз”Ёеә”з”ЁжөҒйҮҸеҜҶй’ҘеҠ еҜҶе№¶еҸ‘йҖҒ
            const encryptedFinished = await this.encryptTls13(clientFinished);
            await writer.write(buildTlsRecord(CONTENT_TYPE_APPLICATION_DATA, encryptedFinished, TLS_VERSION_12));

            this.isTls13 = true;
        }

	// иҜҒд№ҰжҺҘеҸ—пјҲеҗ«еҹәжң¬йӘҢиҜҒпјү
	async acceptCertificate(certificate) {
		if (!certificate?.length) throw new Error('Empty certificate');
		// 1. жңүж•ҲжңҹжЈҖжҹҘ
		if (!isCertificateValid(certificate)) {
			log(`[TLS] иҜҒд№Ұе·ІиҝҮжңҹжҲ–ж— ж•Ҳ`);
			// д»…и®°еҪ•иӯҰе‘ҠпјҢдёҚејәеҲ¶жӢ’з»қпјҲдҝқжҢҒе…је®№жҖ§пјү
		}
		// 2. жңҚеҠЎеҷЁеҗҚз§°йӘҢиҜҒпјҲз®ҖеҢ–зүҲпјү
		if (this.serverName) {
			try {
				const cn = extractCommonNameFromCert(certificate);
				const san = extractSANFromCert(certificate);
				const nameMatches = cn === this.serverName || san.some(s => s === this.serverName || (s.startsWith('*.') && this.serverName.endsWith(s.slice(1))));
				if (!nameMatches) {
					log(`[TLS] иҜҒд№ҰеҗҚз§°дёҚеҢ№й…Қ: ${this.serverName} not in [${san.join(', ')} or CN=${cn}`);
					// д»…и®°еҪ•иӯҰе‘ҠпјҢдёҚејәеҲ¶жӢ’з»қпјҲдҝқжҢҒе…је®№жҖ§пјү
				}
			} catch (e) {
				log(`[TLS] иҜҒд№ҰеҗҚз§°и§ЈжһҗеӨұиҙҘ: ${e.message}`);
			}
		}
		this.sawCert = true;
	}

	// жҙҫз”ҹжөҒйҮҸеҜҶй’Ҙ
	async deriveTrafficKeys(hash, secret, purpose, keyLen, ivLen) {
		const key = await hkdfExpandLabel(hash, secret, purpose, new Uint8Array(0), keyLen);
		const iv = await hkdfExpandLabel(hash, secret, purpose, new Uint8Array(0), ivLen);
		return { key, iv: new Uint8Array(iv) };
	}

	// жһ„е»ә TLS 1.2 Finished
	async buildTls12Finished(secret, transcript) {
		const verifyData = await TLS12PRF(secret, 'client finished', transcript, 12);
		return buildTlsRecord(CONTENT_TYPE_HANDSHAKE, buildHandshakeMessage(HANDSHAKE_TYPE_FINISHED, verifyData));
	}

	// еҶҷе…Ҙж•°жҚ®
	async write(data) {
		const chunk = ж•°жҚ®иҪ¬Uint8Array(data);
		if (!this.handshakeComplete) throw new Error('Handshake not complete');
		if (this.isTls13) {
			const encrypted = await this.encryptTls13(chunk);
			return this.socket.writable.getWriter().write(buildTlsRecord(CONTENT_TYPE_APPLICATION_DATA, encrypted, TLS_VERSION_13));
		} else {
			const encrypted = await this.encryptTls12(chunk, CONTENT_TYPE_APPLICATION_DATA);
			return this.socket.writable.getWriter().write(buildTlsRecord(CONTENT_TYPE_APPLICATION_DATA, encrypted));
		}
	}

	// иҜ»еҸ–ж•°жҚ®
	async read() {
		if (!this.handshakeComplete) throw new Error('Handshake not complete');
		while (true) {
			const { value, done } = await this.readChunk(this.socket.readable.getReader());
			if (done || !value || !value.byteLength) return value;
			this.recordParser.feed(value);
			let record;
			while (record = this.recordParser.next()) {
				if (record.type === CONTENT_TYPE_ALERT) {
					if (record.fragment[1] === ALERT_CLOSE_NOTIFY) return null;
					throw new Error(`TLS Alert: ${record.fragment[1]}`);
				}
				if (record.type !== CONTENT_TYPE_APPLICATION_DATA) continue;
				const plaintext = this.isTls13 ? await this.decryptTls13(record.fragment) : await this.decryptTls12(record.fragment, record.type);
				return plaintext;
			}
		}
	}
}

// TLS иҫ…еҠ©еҮҪж•° - е®Ңж•ҙе®һзҺ°
const TLS_MAX_PLAINTEXT_FRAGMENT = 16 * 1024;

// жһ„е»әTLSи®°еҪ•
function buildTlsRecord(contentType, fragment, version = TLS_VERSION_12) {
	const data = ж•°жҚ®иҪ¬Uint8Array(fragment);
	const record = new Uint8Array(5 + data.byteLength);
	record[0] = contentType;
	record[1] = version >> 8 & 255;
	record[2] = version & 255;
	record[3] = data.byteLength >> 8 & 255;
	record[4] = data.byteLength & 255;
	record.set(data, 5);
	return record;
}

// жһ„е»әжҸЎжүӢж¶ҲжҒҜ
function buildHandshakeMessage(handshakeType, body) {
	const length = body.length;
	return tlsBytes(handshakeType, [length >> 16 & 255, length >> 8 & 255, 255 & length], body);
}

// TLSи®°еҪ•и§ЈжһҗеҷЁ
function TLSи®°еҪ•и§ЈжһҗеҷЁ() {
	this.buffer = new Uint8Array(0);
	this.feed = function(chunk) {
		const bytes = ж•°жҚ®иҪ¬Uint8Array(chunk);
		this.buffer = this.buffer.length ? concatBytes(this.buffer, bytes) : bytes;
	};
	this.next = function() {
		if (this.buffer.length < 5) return null;
		const contentType = this.buffer[0];
		const version = readUint16(this.buffer, 1);
		const length = readUint16(this.buffer, 3);
		if (this.buffer.length < 5 + length) return null;
		const fragment = this.buffer.subarray(5, 5 + length);
		return this.buffer = this.buffer.subarray(5 + length), { type: contentType, version, length, fragment };
	};
}

// TLSжҸЎжүӢи§ЈжһҗеҷЁ
function TLSжҸЎжүӢи§ЈжһҗеҷЁ() {
	this.buffer = new Uint8Array(0);
	this.feed = function(chunk) {
		const bytes = ж•°жҚ®иҪ¬Uint8Array(chunk);
		this.buffer = this.buffer.length ? concatBytes(this.buffer, bytes) : bytes;
	};
	this.next = function() {
		if (this.buffer.length < 4) return null;
		const handshakeType = this.buffer[0];
		const length = readUint24(this.buffer, 1);
		if (this.buffer.length < 4 + length) return null;
		const body = this.buffer.subarray(4, 4 + length);
		const raw = this.buffer.subarray(0, 4 + length);
		return this.buffer = this.buffer.subarray(4 + length), { type: handshakeType, length, body, raw };
	};
}

// и§ЈжһҗServerHello
function parseServerHello(body) {
	let offset = 0;
	const legacyVersion = readUint16(body, offset);
	offset += 2;
	const serverRandom = body.slice(offset, offset + 32);
	offset += 32;
	const sessionIdLength = body[offset++];
	const sessionId = body.slice(offset, offset + sessionIdLength);
	offset += sessionIdLength;
	const cipherSuite = readUint16(body, offset);
	offset += 2;
	const compression = body[offset++];
	let selectedVersion = legacyVersion;
	let keyShare = null;
	let alpn = null;
	if (offset < body.length) {
		const extensionsLength = readUint16(body, offset);
		offset += 2;
		const extensionsEnd = offset + extensionsLength;
		for (; offset + 4 <= extensionsEnd;) {
			const extensionType = readUint16(body, offset);
			offset += 2;
			const extensionLength = readUint16(body, offset);
			offset += 2;
			const extensionData = body.slice(offset, offset + extensionLength);
			if (offset += extensionLength, extensionType === EXT_SUPPORTED_VERSIONS && extensionLength >= 2) selectedVersion = readUint16(extensionData, 0);
			else if (extensionType === EXT_KEY_SHARE && extensionLength >= 4) {
				const group = readUint16(extensionData, 0);
				const keyLength = readUint16(extensionData, 2);
				keyShare = { group, key: extensionData.slice(4, 4 + keyLength) };
			} else if (extensionType === EXT_APPLICATION_LAYER_PROTOCOL_NEGOTIATION && extensionLength >= 3) {
				alpn = TLSж–Үжң¬и§Јз ҒеҷЁ.decode(extensionData.slice(3, 3 + extensionData[2]));
			}
		}
	}
	const helloRetryRequestRandom = new Uint8Array([207, 33, 173, 116, 229, 154, 97, 17, 190, 29, 140, 2, 30, 101, 184, 145, 194, 162, 17, 22, 122, 187, 140, 94, 7, 158, 9, 226, 200, 168, 51, 156]);
	return {
		version: legacyVersion,
		serverRandom,
		sessionId,
		cipherSuite,
		compression,
		selectedVersion,
		keyShare,
		alpn,
		isHRR: constantTimeEqual(serverRandom, helloRetryRequestRandom),
		isTls13: selectedVersion === TLS_VERSION_13
	};
}

// и§ЈжһҗServerKeyExchange (TLS 1.2)
function parseServerKeyExchange(body) {
	let offset = 1;
	const namedCurve = readUint16(body, offset);
	offset += 2;
	const keyLength = body[offset++];
	return { namedCurve, serverPublicKey: body.slice(offset, offset + keyLength) };
}

// жҸҗеҸ–еҸ¶еӯҗиҜҒд№Ұ
function extractLeafCertificate(body, hasContext = 0) {
	let offset = 0;
	if (hasContext) {
		const contextLength = body[offset++];
		offset += contextLength;
	}
	if (offset + 3 > body.length) return null;
	const certificateListLength = readUint24(body, offset);
	offset += 3;
	if (!certificateListLength || offset + 3 > body.length) return null;
	const certificateLength = readUint24(body, offset);
	offset += 3;
	return certificateLength ? body.slice(offset, offset + certificateLength) : null;
}

// з®ҖеҢ–зҡ„ X.509 иҜҒд№Ұи§ЈжһҗпјҲд»…и§Јжһҗеҹәжң¬дҝЎжҒҜпјҢеҗ«е®№й”ҷпјү
function parseX509Certificate(certDer) {
	try {
		const view = new DataView(certDer.buffer, certDer.byteOffset, certDer.byteLength);
		let offset = 0;
		// и§Јжһҗ ASN.1 DER з»“жһ„пјҲеҗ«иҫ№з•ҢжЈҖжҹҘпјү
		function readASN1Length() {
			if (offset >= certDer.length) throw new Error('ASN.1 length: buffer exhausted');
			const firstByte = certDer[offset++];
			if ((firstByte & 0x80) === 0) return firstByte;
			const numBytes = firstByte & 0x7f;
			if (numBytes === 0 || numBytes > 4) throw new Error('ASN.1 length: invalid multi-byte length');
			let length = 0;
			for (let i = 0; i < numBytes; i++) {
				if (offset >= certDer.length) throw new Error('ASN.1 length: buffer exhausted');
				length = (length << 8) | certDer[offset++];
			}
			return length;
		}
		function skipASN1Header(expectedTag) {
			if (offset >= certDer.length) return false;
			if (certDer[offset++] !== expectedTag) return false;
			const len = readASN1Length();
			if (len === false) return false;
			return len;
		}
		// и·іиҝҮеӨ–еұӮ SEQUENCE
		let len = skipASN1Header(0x30);
		if (len === false) return null;
		const outerEnd = offset + len;
		// и§Јжһҗ TBSCertificate
		len = skipASN1Header(0x30);
		if (len === false) return null;
		const tbsStart = offset;
		const tbsEnd = offset + len;
		// и·іиҝҮзүҲжң¬пјҲеҸҜйҖүпјҢcontext [0]пјү
		if (offset < tbsEnd && certDer[offset] === 0xa0) {
			offset++;
			const vLen = readASN1Length();
			offset += vLen;
		}
		// и·іиҝҮеәҸеҲ—еҸ· INTEGER
		if (offset < tbsEnd && certDer[offset] === 0x02) {
			offset++;
			const sLen = readASN1Length();
			offset += sLen;
		}
		if (offset >= tbsEnd) return null;
		// и·іиҝҮзӯҫеҗҚз®—жі•
		len = skipASN1Header(0x30);
		if (len !== false) offset += len;
		if (offset >= tbsEnd) return null;
		// и·іиҝҮйўҒеҸ‘иҖ…
		len = skipASN1Header(0x30);
		if (len !== false) offset += len;
		if (offset >= tbsEnd) return null;
		// и§Јжһҗжңүж•Ҳжңҹ Validity SEQUENCE
		if (offset < tbsEnd && certDer[offset] === 0x30) {
			offset++;
			const vLen = readASN1Length();
			const validityEnd = offset + vLen;
			// и§Јжһҗ notBefore
			if (offset < validityEnd && (certDer[offset] === 0x17 || certDer[offset] === 0x18)) {
				offset++;
				const tLen = readASN1Length();
				offset += tLen;
			}
			// и§Јжһҗ notAfter
			if (offset < validityEnd && (certDer[offset] === 0x17 || certDer[offset] === 0x18)) {
				offset++;
				const tLen = readASN1Length();
				const notAfterStart = offset;
				offset += tLen;
				// жҸҗеҸ– notAfter ж—¶й—ҙеӯ—иҠӮз”ЁдәҺйӘҢиҜҒ
				return { notAfterBytes: certDer.slice(notAfterStart, notAfterStart + tLen) };
			}
		}
		return null;
	} catch (e) {
		return null;
	}
}

// жЈҖжҹҘиҜҒд№ҰжҳҜеҗҰеңЁжңүж•ҲжңҹеҶ…пјҲз®ҖеҢ–зүҲпјҢд»…жЈҖжҹҘ notAfterпјү
function isCertificateValid(certDer) {
	const parsed = parseX509Certificate(certDer);
	if (!parsed || !parsed.notAfterBytes) return false;
	try {
		// е°қиҜ•и§Јжһҗ notAfter ж—¶й—ҙ
		const timeBytes = parsed.notAfterBytes;
		let timeStr = '';
		for (const b of timeBytes) timeStr += String.fromCharCode(b);
		// UTCTime: YYMMDDHHMMSSZ (e.g., 260430120000Z)
		// GeneralizedTime: YYYYMMDDHHMMSSZ
		let year, month, day, hour, minute, second;
		if (timeStr.endsWith('Z')) timeStr = timeStr.slice(0, -1);
		if (timeStr.length === 12) { // UTCTime
			year = parseInt(timeStr.slice(0, 2));
			year = year < 70 ? 2000 + year : 1900 + year;
			month = parseInt(timeStr.slice(2, 4)) - 1;
			day = parseInt(timeStr.slice(4, 6));
			hour = parseInt(timeStr.slice(6, 8));
			minute = parseInt(timeStr.slice(8, 10));
			second = parseInt(timeStr.slice(10, 12));
		} else if (timeStr.length === 14) { // GeneralizedTime
			year = parseInt(timeStr.slice(0, 4));
			month = parseInt(timeStr.slice(4, 6)) - 1;
			day = parseInt(timeStr.slice(6, 8));
			hour = parseInt(timeStr.slice(8, 10));
			minute = parseInt(timeStr.slice(10, 12));
			second = parseInt(timeStr.slice(12, 14));
		} else return false;
		const notAfter = new Date(Date.UTC(year, month, day, hour, minute, second));
		return notAfter > new Date();
	} catch (e) {
		return false;
	}
}

// д»ҺиҜҒд№ҰдёӯжҸҗеҸ– Common NameпјҲз®ҖеҢ–зүҲпјү
function extractCommonNameFromCert(certDer) {
	try {
		// жҗңзҙў CN OID (2.5.4.3 = 06 03 55 04 03)
		const cnOid = [0x06, 0x03, 0x55, 0x04, 0x03];
		for (let i = 0; i < certDer.length - cnOid.length; i++) {
			let match = true;
			for (let j = 0; j < cnOid.length; j++) {
				if (certDer[i + j] !== cnOid[j]) { match = false; break; }
			}
			if (match) {
				let pos = i + cnOid.length;
				const tag = certDer[pos++];
				if (tag !== 0x0c && tag !== 0x13) continue; // UTF8String or PrintableString
				let strLen = certDer[pos++];
				if ((strLen & 0x80) !== 0) {
					const numBytes = strLen & 0x7f;
					strLen = 0;
					for (let j = 0; j < numBytes; j++) strLen = (strLen << 8) | certDer[pos++];
				}
				return TLSж–Үжң¬и§Јз ҒеҷЁ.decode(certDer.slice(pos, pos + strLen));
			}
		}
		return null;
	} catch (e) { return null; }
}

// д»ҺиҜҒд№ҰдёӯжҸҗеҸ– Subject Alternative NamesпјҲз®ҖеҢ–зүҲпјү
function extractSANFromCert(certDer) {
	try {
		const result = [];
		// жҗңзҙў SAN жү©еұ• OID (2.5.29.17 = 06 03 55 1d 11)
		const sanOid = [0x06, 0x03, 0x55, 0x1d, 0x11];
		for (let i = 0; i < certDer.length - sanOid.length; i++) {
			let match = true;
			for (let j = 0; j < sanOid.length; j++) {
				if (certDer[i + j] !== sanOid[j]) { match = false; break; }
			}
			if (match) {
				let pos = i + sanOid.length;
				if (certDer[pos++] !== 0x04) continue; // OCTET STRING
				let sanLen = certDer[pos++];
				if ((sanLen & 0x80) !== 0) {
					const numBytes = sanLen & 0x7f;
					sanLen = 0;
					for (let j = 0; j < numBytes; j++) sanLen = (sanLen << 8) | certDer[pos++];
				}
				const sanEnd = pos + sanLen;
				while (pos < sanEnd) {
					const tag = certDer[pos++];
					let strLen = certDer[pos++];
					if ((strLen & 0x80) !== 0) {
						const numBytes = strLen & 0x7f;
						strLen = 0;
						for (let j = 0; j < numBytes; j++) strLen = (strLen << 8) | certDer[pos++];
					}
					if (tag === 2) { // dNSName
						result.push(TLSж–Үжң¬и§Јз ҒеҷЁ.decode(certDer.slice(pos, pos + strLen)));
					}
					pos += strLen;
				}
				return result;
			}
		}
		return result;
	} catch (e) { return []; }
}

// и§ЈжһҗEncryptedExtensions
function parseEncryptedExtensions(body) {
	const parsed = { alpn: null };
	let offset = 2;
	const extensionsEnd = 2 + readUint16(body, 0);
	for (; offset + 4 <= extensionsEnd;) {
		const extensionType = readUint16(body, offset);
		offset += 2;
		const extensionLength = readUint16(body, offset);
		if (offset += 2, extensionType === EXT_APPLICATION_LAYER_PROTOCOL_NEGOTIATION && extensionLength >= 3) {
			const protocolLength = body[offset + 2];
			if (protocolLength > 0 && offset + 3 + protocolLength <= offset + extensionLength) {
				parsed.alpn = TLSж–Үжң¬и§Јз ҒеҷЁ.decode(body.slice(offset + 3, offset + 3 + protocolLength));
			}
		}
		offset += extensionLength;
	}
	return parsed;
}

// жһ„е»әClientHello
function buildClientHello(clientRandom, serverName, keyShares, { tls13: enableTls13 = true, tls12: enableTls12 = true, alpn = null, chacha = true } = {}) {
	const cipherIds = [];
	if (enableTls13) {
		cipherIds.push(4865, 4866);
		if (chacha) cipherIds.push(4867);
	}
	if (enableTls12) {
		cipherIds.push(49199, 49200, 49195, 49196);
		if (chacha) cipherIds.push(52392, 52393);
	}
	const cipherBytes = tlsBytes(...cipherIds.flatMap(uint16be));
	const extensions = [tlsBytes(255, 1, 0, 1, 0)];
	if (serverName) {
		const serverNameBytes = TLSж–Үжң¬зј–з ҒеҷЁ.encode(serverName);
		const serverNameList = tlsBytes(0, uint16be(serverNameBytes.length), serverNameBytes);
		extensions.push(tlsBytes(uint16be(EXT_SERVER_NAME), uint16be(serverNameList.length + 2), uint16be(serverNameList.length), serverNameList));
	}
	if (keyShares) {
		const keyShareEntries = [];
		const supportedGroupsExt = tlsBytes(uint16be(EXT_SUPPORTED_GROUPS), 4, 0, 1, 0);
		for (const [groupId, keyShare] of keyShares) {
			const publicKeyBytes = keyShare.publicKeyRaw;
			keyShareEntries.push(tlsBytes(uint16be(groupId), uint16be(publicKeyBytes.length), publicKeyBytes));
		}
		if (keyShareEntries.length) {
			const keyShareExt = tlsBytes(0, concatBytes(...keyShareEntries));
			extensions.push(tlsBytes(uint16be(EXT_KEY_SHARE), uint16be(keyShareExt.length), keyShareExt));
		}
		extensions.push(supportedGroupsExt);
	}
	const supportedVersions = [];
	if (enableTls13) supportedVersions.push(TLS_VERSION_13);
	if (enableTls12) supportedVersions.push(TLS_VERSION_12);
	extensions.push(tlsBytes(uint16be(EXT_SUPPORTED_VERSIONS), supportedVersions.length + 1, supportedVersions.length, ...supportedVersions));
	if (alpn) {
		const alpnBytes = TLSж–Үжң¬зј–з ҒеҷЁ.encode(alpn);
		extensions.push(tlsBytes(uint16be(EXT_APPLICATION_LAYER_PROTOCOL_NEGOTIATION), tlsBytes(alpnBytes.length + 1, alpnBytes.length, alpnBytes)));
	}
	if (chacha) {
		extensions.push(tlsBytes(uint16be(EXT_EC_POINT_FORMATS), 2, 1, 0));
	}
	const clientHello = tlsBytes(
		TLS_VERSION_12,
		clientRandom,
		tlsBytes(0),
		cipherBytes,
		tlsBytes(1, 0),
		tlsBytes(uint16be(concatBytes(...extensions).length), ...extensions)
	);
	return buildHandshakeMessage(HANDSHAKE_TYPE_CLIENT_HELLO, clientHello);
}

function xorSequenceIntoIv(iv, sequenceNumber) {
	const nonce = iv.slice();
	const sequenceBytes = uint64be(sequenceNumber);
	for (let index = 0; index < 8; index++) nonce[nonce.length - 8 + index] ^= sequenceBytes[index];
	return nonce;
}

async function еҲӣе»әSSеҮәз«ҷеҠ еҜҶеҷЁ(config, passwordText) {
	const masterKey = await SSжҙҫз”ҹдё»еҜҶй’Ҙ(passwordText, config.keyLen);
	const salt = crypto.getRandomValues(new Uint8Array(config.saltLen));
	const encryptKey = await SSжҙҫз”ҹдјҡиҜқеҜҶй’Ҙ(config, masterKey, salt, ['encrypt']);
	const nonceCounter = new Uint8Array(SSNonceй•ҝеәҰ);
	let saltSent = false;
	return {
		async еҠ еҜҶ(dataChunk) {
			const plaintextData = SSж•°жҚ®иҪ¬Uint8Array(dataChunk);
			const outboundChunks = [];
			if (!saltSent) {
				outboundChunks.push(salt);
				saltSent = true;
			}
			if (plaintextData.byteLength === 0) return SSжӢјжҺҘеӯ—иҠӮ(...outboundChunks);
			let offset = 0;
			while (offset < plaintextData.byteLength) {
				const end = Math.min(offset + config.maxChunk, plaintextData.byteLength);
				const payloadPlain = plaintextData.subarray(offset, end);
				const lengthPlain = new Uint8Array(2);
				SSеҶҷе…ҘU16BE(lengthPlain, 0, payloadPlain.byteLength);
				const lengthCipher = await SSAEADеҠ еҜҶ(encryptKey, nonceCounter, lengthPlain);
				const payloadCipher = await SSAEADеҠ еҜҶ(encryptKey, nonceCounter, payloadPlain);
				outboundChunks.push(lengthCipher, payloadCipher);
				offset = end;
			}
			return SSжӢјжҺҘеӯ—иҠӮ(...outboundChunks);
		},
	};
}

function еҲӣе»әSSеӣһеҢ…Socket(realSocket, outboundEncryptor) {
	let sendChain = Promise.resolve();
	return {
		get readyState() { return realSocket.readyState; },
		send(data) {
			const chunk = SSж•°жҚ®иҪ¬Uint8Array(data);
			sendChain = sendChain.then(async () => {
				if (realSocket.readyState !== WebSocket.OPEN) return;
				const encrypted = await outboundEncryptor.еҠ еҜҶ(chunk);
				if (encrypted.byteLength > 0 && realSocket.readyState === WebSocket.OPEN) {
					realSocket.send(encrypted.buffer);
				}
			}).catch((error) => {
				log(`[SSеҸ‘йҖҒ] еҠ еҜҶеӨұиҙҘ: ${error?.message || error}`);
				closeSocketQuietly(realSocket);
			});
		},
		close() { closeSocketQuietly(realSocket); }
	};
}

function и§ЈжһҗSSиҜ·жұӮ(chunk, passwordPlainText) {
	const _ = passwordPlainText;
	const data = SSж•°жҚ®иҪ¬Uint8Array(chunk);
	// еҠ ејәиҫ№з•ҢжЈҖжҹҘпјҡжңҖе°Ҹй•ҝеәҰжЈҖжҹҘпјҲ1еӯ—иҠӮзұ»еһӢ + иҮіе°‘1еӯ—иҠӮж•°жҚ® + 2еӯ—иҠӮз«ҜеҸЈпјү
	if (!data || data.byteLength < 3) return { hasError: true, message: 'invalid ss data: too short' };
	const addressType = data[0];
	let cursor = 1;
	let hostname = '';
	if (addressType === 1) { // IPv4
		if (data.byteLength < cursor + 4 + 2) return { hasError: true, message: 'invalid ss ipv4 length' };
		hostname = `${data[cursor]}.${data[cursor + 1]}.${data[cursor + 2]}.${data[cursor + 3]}`;
		cursor += 4;
	} else if (addressType === 3) { // Domain
		if (data.byteLength < cursor + 1) return { hasError: true, message: 'invalid ss domain length' };
		const domainLength = data[cursor];
		if (domainLength === 0 || domainLength > 253) return { hasError: true, message: 'invalid ss domain length value' };
		cursor += 1;
		if (data.byteLength < cursor + domainLength + 2) return { hasError: true, message: 'invalid ss domain data' };
		hostname = SSж–Үжң¬и§Јз ҒеҷЁ.decode(data.subarray(cursor, cursor + domainLength));
		cursor += domainLength;
	} else if (addressType === 4) { // IPv6
		if (data.byteLength < cursor + 16 + 2) return { hasError: true, message: 'invalid ss ipv6 length' };
		const ipv6 = [];
		const ipv6View = new DataView(data.buffer, data.byteOffset + cursor, 16);
		for (let i = 0; i < 8; i++) ipv6.push(ipv6View.getUint16(i * 2).toString(16));
		hostname = ipv6.join(':');
		cursor += 16;
	} else {
		return { hasError: true, message: `invalid ss addressType: ${addressType}` };
	}
	if (!hostname) return { hasError: true, message: `invalid ss address: ${addressType}` };
	// жЈҖжҹҘз«ҜеҸЈиҫ№з•Ң
	if (cursor + 2 > data.byteLength) return { hasError: true, message: 'invalid ss port: out of bounds' };
	const port = (data[cursor] << 8) | data[cursor + 1];
	if (port < 1 || port > 65535) return { hasError: true, message: `invalid ss port: ${port}` };
	cursor += 2;
	return { hasError: false, addressType, port, hostname, rawClientData: data.subarray(cursor) };
}

async function forwardataTCP(host, portNum, rawData, ws, respHeader, remoteConnWrapper, yourUUID, env, и®ҝй—®IP, ctx2) {
    // д»Һ ctx2 и§Јжһ„еҸҳйҮҸпјҢзЎ®дҝқдҪңз”ЁеҹҹжҳҺзЎ®
    const { еҸҚд»ЈIP, еҗҜз”ЁSOCKS5еҸҚд»Ј, еҗҜз”ЁSOCKS5е…ЁеұҖеҸҚд»Ј, еҗҜз”ЁеҸҚд»Је…ңеә•, log } = ctx2;
    
