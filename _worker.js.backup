                            if (еҲӨж–ӯжҳҜеҗҰжҳҜжңЁй©¬) {
                                const и§Јжһҗз»“жһң = и§ЈжһҗжңЁй©¬иҜ·жұӮ(йҰ–еҢ…buffer, yourUUID);
                                if (и§Јжһҗз»“жһң?.hasError) throw new Error(и§Јжһҗз»“жһң.message || 'Invalid trojan request');
                                const { port, hostname, rawClientData } = и§Јжһҗз»“жһң;
                                //console.log(`[gRPC] жңЁй©¬йҰ–еҢ…: ${hostname}:${port}`);
                                if (isSpeedTestSite(hostname)) throw new Error('Speedtest site is blocked');
                                await forwardataTCP(hostname, port, rawClientData, grpcBridge, null, remoteConnWrapper, yourUUID, env, и®ҝй—®IP, ctx2);
                            } else {
