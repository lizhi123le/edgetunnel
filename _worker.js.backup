// SSRF йҳІжҠӨпјҡжЈҖжҹҘзӣ®ж Үең°еқҖжҳҜеҗҰдёәеҶ…зҪ‘/еҚұйҷ©ең°еқҖ
function жҳҜеҗҰдёәеҶ…зҪ‘ең°еқҖ(host) {
    if (!host) return true;
    const е°ҸеҶҷHost = host.toLowerCase().trim();    
    // жЈҖжҹҘ localhost еҸҳдҪ“
    if (е°ҸеҶҷHost === 'localhost' || е°ҸеҶҷHost.endsWith('.localhost') || е°ҸеҶҷHost === '127.0.0.1' || е°ҸеҶҷHost === '::1') return true;    
    // жЈҖжҹҘ IPv4 з§Ғжңүең°еқҖ
    const ipv4з§ҒжңүжӯЈеҲҷ = /^(10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.|127\.|169\.254\.|0\.|224\.|239\.|255\.)/;
    if (ipv4з§ҒжңүжӯЈеҲҷ.test(е°ҸеҶҷHost)) return true;    
    // жЈҖжҹҘ IPv6 з§Ғжңүең°еқҖ
    if (е°ҸеҶҷHost.startsWith('fc') || е°ҸеҶҷHost.startsWith('fd') || е°ҸеҶҷHost.includes('fe80::') || е°ҸеҶҷHost.startsWith('::1')) return true;    
    // жЈҖжҹҘ Cloudflare еҶ…йғЁеҹҹеҗҚпјҲйҳІжӯўи®ҝй—®еҶ…йғЁжңҚеҠЎпјү
    const зҰҒжӯўеҹҹеҗҚеҗҺзјҖ = ['.internal', '.local', '.cloudflareworkers.com', '.cloudflare-ipfs.com'];
    if (зҰҒжӯўеҹҹеҗҚеҗҺзјҖ.some(suffix => е°ҸеҶҷHost.endsWith(suffix))) return true;    
    return false;
}

// URL е®үе…ЁйӘҢиҜҒпјҡйӘҢиҜҒдјӘиЈ…йЎө URL
function йӘҢиҜҒдјӘиЈ…йЎөURL(urlж–Үжң¬) {
    try {
        if (!urlж–Үжң¬ || urlж–Үжң¬ === 'nginx' || urlж–Үжң¬ === '1101') return { valid: true, url: urlж–Үжң¬ };
        let йӘҢиҜҒURL = urlж–Үжң¬.trim().replace(/\/$/, '');
        if (!йӘҢиҜҒURL.match(/^https?:\/\//i)) йӘҢиҜҒURL = 'https://' + йӘҢиҜҒURL;
        if (йӘҢиҜҒURL.toLowerCase().startsWith('http://')) йӘҢиҜҒURL = 'https://' + йӘҢиҜҒURL.substring(7);
        const u = new URL(йӘҢиҜҒURL);
        if (u.protocol !== 'https:') return { valid: false, error: 'д»…ж”ҜжҢҒ HTTPS еҚҸи®®' };
        if (жҳҜеҗҰдёәеҶ…зҪ‘ең°еқҖ(u.hostname)) return { valid: false, error: 'зҰҒжӯўдҪҝз”ЁеҶ…зҪ‘ең°еқҖ' };
        return { valid: true, url: u.protocol + '//' + u.host };
    } catch (e) {
        return { valid: false, error: 'ж— ж•Ҳзҡ„ URL ж јејҸ' };
    }
}

async function SSAEADеҠ еҜҶ(cryptoKey, nonceCounter, plaintext) {
	const iv = nonceCounter.slice();
	const ciphertext = await crypto.subtle.encrypt({ name: 'AES-GCM', iv, tagLength: 128 }, cryptoKey, plaintext);
	SSйҖ’еўһNonceи®Ўж•°еҷЁ(nonceCounter);
	return new Uint8Array(ciphertext);
}

async function SSAEADи§ЈеҜҶ(cryptoKey, nonceCounter, ciphertext) {
	const iv = nonceCounter.slice();
	const plaintext = await crypto.subtle.decrypt({ name: 'AES-GCM', iv, tagLength: 128 }, cryptoKey, ciphertext);
	SSйҖ’еўһNonceи®Ўж•°еҷЁ(nonceCounter);
	return new Uint8Array(plaintext);
}

function еҲӣе»әSSе…Ҙз«ҷи§ЈеҜҶеҷЁ(config, passwordText) {
	const state = {
		buffer: new Uint8Array(0),
		hasSalt: false,
		waitPayloadLength: null,
		decryptKey: null,
		nonceCounter: new Uint8Array(SSNonceй•ҝеәҰ),
	};
	const masterKeyPromise = SSжҙҫз”ҹдё»еҜҶй’Ҙ(passwordText, config.keyLen);
	return {
		async иҫ“е…Ҙ(dataChunk) {
			const chunk = SSж•°жҚ®иҪ¬Uint8Array(dataChunk);
			if (chunk.byteLength > 0) state.buffer = SSжӢјжҺҘеӯ—иҠӮ(state.buffer, chunk);
			if (!state.hasSalt) {
				if (state.buffer.byteLength < config.saltLen) return [];
				const salt = state.buffer.subarray(0, config.saltLen);
